<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      Background="Black">

  <Grid.Resources>
    <ResourceDictionary>

      <!-- === Shared Converter === -->
      <BooleanToVisibilityConverter x:Key="BoolToVis" />

      <!-- === Shared Button ControlTemplate === -->
      <ControlTemplate x:Key="GameButtonTemplate" TargetType="Button">
        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="10,5">
          <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>

      <!-- === Sprite Item Template (character body + weapon + flash) === -->
      <DataTemplate x:Key="SpriteItemTemplate">
        <Canvas IsHitTestVisible="False">
          <!-- Body sprite -->
          <Rectangle Width="{Binding bodyW}" Height="{Binding bodyH}"
                     Opacity="{Binding bodyOpacity}"
                     RenderTransformOrigin="0.5,1" IsHitTestVisible="False">
            <Rectangle.Fill>
              <ImageBrush ImageSource="{Binding bodyTexture}" Stretch="Uniform" />
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
              <TransformGroup>
                <ScaleTransform ScaleX="{Binding bodyScaleX}" ScaleY="{Binding bodyScaleY}" />
                <RotateTransform Angle="{Binding bodyRotation}" />
              </TransformGroup>
            </Rectangle.RenderTransform>
          </Rectangle>

          <!-- Weapon sprite -->
          <Rectangle Canvas.Left="{Binding weaponOffsetX}" Canvas.Top="{Binding weaponOffsetY}"
                     Width="{Binding weaponW}" Height="{Binding weaponH}"
                     Opacity="{Binding weaponOpacity}"
                     Visibility="{Binding weaponVisible, Converter={StaticResource BoolToVis}}"
                     RenderTransformOrigin="0.5,0.5" IsHitTestVisible="False">
            <Rectangle.Fill>
              <ImageBrush ImageSource="{Binding weaponTexture}" Stretch="Uniform" />
            </Rectangle.Fill>
            <Rectangle.RenderTransform>
              <TransformGroup>
                <ScaleTransform ScaleX="{Binding weaponScaleX}" ScaleY="{Binding weaponScaleY}" />
                <RotateTransform Angle="{Binding weaponRotation}" />
              </TransformGroup>
            </Rectangle.RenderTransform>
          </Rectangle>

          <!-- Flash overlay (OpacityMask for pixel-perfect silhouette flash) -->
          <Rectangle Width="{Binding bodyW}" Height="{Binding bodyH}"
                     Opacity="{Binding flashOpacity}"
                     Fill="{Binding flashColor}"
                     Visibility="{Binding flashVisible, Converter={StaticResource BoolToVis}}"
                     RenderTransformOrigin="0.5,1" IsHitTestVisible="False">
            <Rectangle.OpacityMask>
              <ImageBrush ImageSource="{Binding flashTexture}" Stretch="Uniform" />
            </Rectangle.OpacityMask>
            <Rectangle.RenderTransform>
              <TransformGroup>
                <ScaleTransform ScaleX="{Binding flashScaleX}" ScaleY="{Binding flashScaleY}" />
              </TransformGroup>
            </Rectangle.RenderTransform>
          </Rectangle>
        </Canvas>
      </DataTemplate>

      <!-- === Sprite Container Style === -->
      <Style x:Key="SpriteContainerStyle" TargetType="ContentPresenter">
        <Setter Property="Canvas.Left" Value="{Binding posX}" />
        <Setter Property="Canvas.Top" Value="{Binding posY}" />
        <Setter Property="Panel.ZIndex" Value="{Binding priority}" />
        <Setter Property="Visibility" Value="{Binding visible, Converter={StaticResource BoolToVis}}" />
      </Style>

      <!-- === HUD Template === -->
      <DataTemplate x:Key="HudTemplate">
        <Grid Visibility="{Binding hudVisible, Converter={StaticResource BoolToVis}}">

          <!-- === TOP PANEL === -->
          <Border VerticalAlignment="Top" HorizontalAlignment="Stretch"
                  Background="#E8060A14" CornerRadius="0,0,18,18"
                  BorderBrush="#40507090" BorderThickness="0,0,0,1"
                  Padding="10,6,10,10" Margin="0,0,0,0">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
              </Grid.RowDefinitions>

              <!-- Row 0: HP Bar -->
              <Grid Grid.Row="0" Margin="46,2,0,0">
                <Border Height="18" CornerRadius="9" Background="#40200808">
                  <Border CornerRadius="9" HorizontalAlignment="Left"
                          Background="{Binding hpBarColorHex}"
                          Width="{Binding hpBarWidth}" Height="18" />
                </Border>
                <Border Height="18" CornerRadius="9" HorizontalAlignment="Left"
                        Width="{Binding hpBarWidth}" Opacity="0.35">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#80FFFFFF" Offset="0" />
                      <GradientStop Color="#00FFFFFF" Offset="0.6" />
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
                <TextBlock Text="{Binding hpText}" FontSize="10" FontWeight="Bold" Foreground="#E0FFFFFF"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />
              </Grid>

              <!-- Row 1: XP/Level Bar -->
              <Grid Grid.Row="1" Margin="46,4,0,0">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#30507090" CornerRadius="4" Padding="5,1,5,1" Margin="0,0,6,0">
                  <TextBlock FontSize="10" FontWeight="Bold" Foreground="#A0E0FF" VerticalAlignment="Center">
                    <Run Text="Lv " /><Run Text="{Binding playerLevel}" />
                  </TextBlock>
                </Border>
                <Grid Grid.Column="1">
                  <Border Height="8" CornerRadius="4" Background="#18203A">
                    <Border CornerRadius="4" HorizontalAlignment="Left"
                            Background="#5090FF"
                            Width="{Binding levelBarWidth}" Height="8" />
                  </Border>
                  <Border Height="4" CornerRadius="2" HorizontalAlignment="Left"
                          Width="{Binding levelBarWidth}" Margin="0,1,0,0" Opacity="0.4">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#80FFFFFF" Offset="0" />
                        <GradientStop Color="#00FFFFFF" Offset="1" />
                      </LinearGradientBrush>
                    </Border.Background>
                  </Border>
                  <TextBlock Text="{Binding levelBarText}" FontSize="8" Foreground="#5070A0"
                             HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0" />
                </Grid>
              </Grid>

              <!-- Row 2: Coins (left) and Enemy Count (right) -->
              <Grid Grid.Row="2" Margin="46,5,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                  <Border Background="#30C08000" CornerRadius="10" Width="22" Height="22">
                    <Rectangle Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Rectangle.Fill><ImageBrush ImageSource="{Binding hudCoinCountTexture}" Stretch="Uniform" /></Rectangle.Fill>
                    </Rectangle>
                  </Border>
                  <TextBlock Text="{Binding coinCountText}" FontSize="14" FontWeight="Bold" Foreground="#FFD740"
                             Margin="5,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                  <Border Background="#30204060" CornerRadius="10" Width="22" Height="22">
                    <Rectangle Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                      <Rectangle.Fill><ImageBrush ImageSource="{Binding hudEnnemiCountTexture}" Stretch="Uniform" /></Rectangle.Fill>
                    </Rectangle>
                  </Border>
                  <TextBlock Text="{Binding enemyCountText}" FontSize="14" FontWeight="SemiBold" Foreground="#D0E0FF"
                             Margin="5,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
              </Grid>
            </Grid>
          </Border>

          <!-- Pause Button (top-left, overlapping panel) -->
          <Button Width="44" Height="44" VerticalAlignment="Top" HorizontalAlignment="Left"
                  Margin="4,4,0,0" Background="Transparent" BorderThickness="0"
                  Command="{Binding events.onPauseClicked}" IsHitTestVisible="True">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Grid>
                  <Rectangle Width="44" Height="44">
                    <Rectangle.Fill><ImageBrush ImageSource="{Binding hudPauseButtonTexture}" Stretch="Uniform" /></Rectangle.Fill>
                  </Rectangle>
                </Grid>
              </ControlTemplate>
            </Button.Template>
          </Button>

          <!-- === BOTTOM WAVE PANEL === -->
          <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                  Background="#D0060A14" CornerRadius="20"
                  BorderBrush="#40507090" BorderThickness="1"
                  Padding="18,8,18,10"
                  Margin="0,0,0,20">
            <StackPanel HorizontalAlignment="Center">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5">
                <TextBlock FontSize="11" FontWeight="Bold" Foreground="#5070A0"
                           VerticalAlignment="Center" Margin="0,0,4,0">WAVE</TextBlock>
                <TextBlock FontSize="18" FontWeight="Bold" Foreground="#E0EEFF"
                           VerticalAlignment="Center" Text="{Binding waveNumber}" />
              </StackPanel>
              <!-- Timer bar -->
              <Grid Width="180" Height="12">
                <Border CornerRadius="6" Background="#18101820" Height="12">
                  <Border CornerRadius="6" HorizontalAlignment="Left"
                          Background="{Binding timerColorHex}"
                          Width="{Binding timerBarWidth}" Height="12" />
                </Border>
                <Border CornerRadius="6" HorizontalAlignment="Left"
                        Width="{Binding timerBarWidth}" Height="6" Margin="0,1,0,0" Opacity="0.35">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#80FFFFFF" Offset="0" />
                      <GradientStop Color="#00FFFFFF" Offset="1" />
                    </LinearGradientBrush>
                  </Border.Background>
                </Border>
              </Grid>
              <!-- Wave progress dots row -->
              <Grid Width="100" Height="6" Margin="0,5,0,0" HorizontalAlignment="Center">
                <Rectangle Width="100" Height="6" RadiusX="3" RadiusY="3">
                  <Rectangle.Fill><ImageBrush ImageSource="{Binding hudWaveBarContourTexture}" Stretch="Fill" /></Rectangle.Fill>
                </Rectangle>
                <Border CornerRadius="3" HorizontalAlignment="Left"
                        Background="{Binding timerColorHex}"
                        Width="{Binding waveBarWidth}" Height="4" Margin="1" />
              </Grid>
            </StackPanel>
          </Border>

          <!-- Wave Announcement (center) -->
          <Grid Visibility="{Binding waveAnnouncementVisible, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Background="#D0060A14" CornerRadius="14" BorderBrush="#405090C0" BorderThickness="1"
                    Padding="28,12">
              <TextBlock Text="{Binding waveAnnouncementText}" FontSize="26" FontWeight="Bold"
                         Foreground="#E0EEFF" HorizontalAlignment="Center" />
            </Border>
          </Grid>

          <!-- Elite Warning (center, slightly above center) -->
          <Grid Visibility="{Binding eliteWarningVisible, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-80,0,0">
            <Border Background="#D0180800" CornerRadius="12" BorderBrush="#60FF6010" BorderThickness="1.5"
                    Padding="22,10">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="&#x26A0; " FontSize="18" Foreground="#FF8020" VerticalAlignment="Center" />
                <TextBlock Text="ELITE INCOMING!" FontSize="20" FontWeight="Bold"
                           Foreground="#FF9030" VerticalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>

          <!-- Boss Warning (center) -->
          <Grid Visibility="{Binding bossWarningVisible, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-130,0,0">
            <Border Background="#D0200000" CornerRadius="12" BorderBrush="#80FF2020" BorderThickness="1.5"
                    Padding="22,10">
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <TextBlock Text="&#x2620; " FontSize="18" Foreground="#FF4040" VerticalAlignment="Center" />
                <TextBlock Text="BOSS INCOMING!" FontSize="22" FontWeight="Bold"
                           Foreground="#FF5050" VerticalAlignment="Center" />
              </StackPanel>
            </Border>
          </Grid>

          <!-- Boss HP Bar (top, below HUD panel) -->
          <Grid Visibility="{Binding bossHpBarVisible, Converter={StaticResource BoolToVis}}"
                VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,82,0,0">
            <Border CornerRadius="8" Background="#60000000" Padding="4,3">
              <StackPanel>
                <TextBlock Text="BOSS" FontSize="9" FontWeight="Bold" Foreground="#FF6060"
                           HorizontalAlignment="Center" Margin="0,0,0,2" />
                <Border Height="12" Width="320" CornerRadius="6" Background="#40200000">
                  <Border CornerRadius="6" HorizontalAlignment="Left"
                          Background="#D02020"
                          Width="{Binding bossHpBarWidth}" Height="12" />
                </Border>
                <TextBlock Text="{Binding bossHpBarText}" FontSize="9" Foreground="#F0A0A0"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0" />
              </StackPanel>
            </Border>
          </Grid>
        </Grid>
      </DataTemplate>

      <!-- === Pause Menu Template === -->
      <DataTemplate x:Key="PauseMenuTemplate">
        <Grid Visibility="{Binding pauseMenuVisible, Converter={StaticResource BoolToVis}}"
              Background="#D912121A">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="PAUSED" FontSize="36" FontWeight="Bold" Foreground="#F0F0F8"
                       HorizontalAlignment="Center" Margin="0,0,0,30" />
            <Button Content="RESUME" Command="{Binding events.onResumeClicked}"
                    Width="180" Height="50" FontSize="18" FontWeight="Bold"
                    Background="#4080F0" Foreground="White" BorderThickness="0" Margin="0,0,0,12"
                    Template="{StaticResource GameButtonTemplate}" />
            <Button Content="RESTART" Command="{Binding events.onRestartClicked}"
                    Width="180" Height="50" FontSize="18" FontWeight="Bold"
                    Background="#E94560" Foreground="White" BorderThickness="0"
                    Template="{StaticResource GameButtonTemplate}" />
          </StackPanel>
        </Grid>
      </DataTemplate>

      <!-- === Upgrade Screen Template === -->
      <DataTemplate x:Key="UpgradeScreenTemplate">
        <Grid Visibility="{Binding upgradeScreenVisible, Converter={StaticResource BoolToVis}}"
              Background="#F0080810">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="340">
            <Border Height="3" Width="80" Background="#FFD740" CornerRadius="2"
                    HorizontalAlignment="Center" Margin="0,0,0,14" />
            <TextBlock Text="LEVEL UP!" FontSize="30" FontWeight="Bold" Foreground="#FFD740"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Choose an upgrade:" FontSize="13" Foreground="#8090A0"
                       HorizontalAlignment="Center" Margin="0,0,0,20" />
            <Border Height="1" Width="260" Background="#20406080" CornerRadius="1"
                    HorizontalAlignment="Center" Margin="0,0,0,18" />

            <!-- Upgrade Card 0 -->
            <Button Command="{Binding events.onUpgrade0Clicked}"
                    Visibility="{Binding upgrade0Visible, Converter={StaticResource BoolToVis}}"
                    Width="310" Height="84" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="#50182840" CornerRadius="10" BorderBrush="#7060B0" BorderThickness="1.5" Padding="14,10">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding upgrade0Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                        <TextBlock Text="{Binding upgrade0Level}" FontSize="11" Foreground="#80D0FF"
                                   Margin="10,3,0,0" VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock Text="{Binding upgrade0Desc}" FontSize="12" Foreground="#9098A8"
                                 Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Upgrade Card 1 -->
            <Button Command="{Binding events.onUpgrade1Clicked}"
                    Visibility="{Binding upgrade1Visible, Converter={StaticResource BoolToVis}}"
                    Width="310" Height="84" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="#50182840" CornerRadius="10" BorderBrush="#7060B0" BorderThickness="1.5" Padding="14,10">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding upgrade1Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                        <TextBlock Text="{Binding upgrade1Level}" FontSize="11" Foreground="#80D0FF"
                                   Margin="10,3,0,0" VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock Text="{Binding upgrade1Desc}" FontSize="12" Foreground="#9098A8"
                                 Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>

            <!-- Upgrade Card 2 -->
            <Button Command="{Binding events.onUpgrade2Clicked}"
                    Visibility="{Binding upgrade2Visible, Converter={StaticResource BoolToVis}}"
                    Width="310" Height="84" Background="Transparent" BorderThickness="0" Margin="0,0,0,10">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="#50182840" CornerRadius="10" BorderBrush="#7060B0" BorderThickness="1.5" Padding="14,10">
                    <StackPanel>
                      <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding upgrade2Name}" FontSize="16" FontWeight="Bold" Foreground="#F0F0F8" />
                        <TextBlock Text="{Binding upgrade2Level}" FontSize="11" Foreground="#80D0FF"
                                   Margin="10,3,0,0" VerticalAlignment="Center" />
                      </StackPanel>
                      <TextBlock Text="{Binding upgrade2Desc}" FontSize="12" Foreground="#9098A8"
                                 Margin="0,5,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </DataTemplate>

      <!-- === Title Screen Template === -->
      <DataTemplate x:Key="TitleScreenTemplate">
        <Grid Visibility="{Binding titleVisible, Converter={StaticResource BoolToVis}}"
              Background="#CC12121A">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="ARENA" FontSize="56" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#F0F0F8" HorizontalAlignment="Center"
                       CharacterSpacing="200" Margin="0,0,0,-10" />
            <TextBlock Text="VERMIN" FontSize="56" FontWeight="Bold" FontFamily="Teko"
                       Foreground="#E94560" HorizontalAlignment="Center"
                       CharacterSpacing="200" Margin="0,0,0,30" />
            <Border Height="2" Width="160" Background="#4080F0"
                    HorizontalAlignment="Center" Margin="0,0,0,30" CornerRadius="1" />
            <Button Content="START" Command="{Binding events.onStartClicked}"
                    Width="180" Height="50" FontSize="20" FontWeight="Bold"
                    Background="#E94560" Foreground="White" BorderThickness="0"
                    Template="{StaticResource GameButtonTemplate}" />
          </StackPanel>
        </Grid>
      </DataTemplate>

      <!-- === Death Overlay Template (fades in during death animation) === -->
      <DataTemplate x:Key="DeathOverlayTemplate">
        <Grid Visibility="{Binding deathOverlayVisible, Converter={StaticResource BoolToVis}}"
              Background="#12121A" Opacity="{Binding deathOverlayOpacity}"
              IsHitTestVisible="False" />
      </DataTemplate>

      <!-- === Death Screen Template === -->
      <DataTemplate x:Key="DeathScreenTemplate">
        <Grid Visibility="{Binding deathScreenVisible, Converter={StaticResource BoolToVis}}">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border Height="3" Width="60" Background="#E94560" CornerRadius="2"
                    HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBlock Text="DEFEATED" FontSize="34" FontWeight="Bold" Foreground="#E94560"
                       HorizontalAlignment="Center" Margin="0,0,0,6" />
            <Border Height="1" Width="140" Background="#30E94560" CornerRadius="1"
                    HorizontalAlignment="Center" Margin="0,0,0,20" />

            <!-- Stats card -->
            <Border Background="#30182030" CornerRadius="10" Padding="20,14" Margin="0,0,0,20"
                    BorderBrush="#20E94560" BorderThickness="1">
              <StackPanel>
                <TextBlock Text="{Binding deathWavesText}" FontSize="15" Foreground="#D0D0E0"
                           HorizontalAlignment="Center" Margin="0,0,0,10" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                  <Ellipse Width="14" Height="14" Fill="#F0C030" Stroke="#C08020" StrokeThickness="1" />
                  <TextBlock Text="{Binding deathCoinsText}" FontSize="14" Foreground="#FFD740"
                             Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                  <Ellipse Width="14" Height="14" Fill="#30D060" Stroke="#20A040" StrokeThickness="1" />
                  <TextBlock Text="{Binding deathXpText}" FontSize="14" Foreground="#60E080"
                             Margin="6,0,0,0" VerticalAlignment="Center" />
                </StackPanel>
              </StackPanel>
            </Border>

            <Button Content="RETRY" Command="{Binding events.onRetryClicked}"
                    Width="200" Height="52" FontSize="18" FontWeight="Bold"
                    Background="#E94560" Foreground="White" BorderThickness="0" Margin="0,0,0,12">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
            <Button Content="MENU" Command="{Binding events.onReturnToMenuClicked}"
                    Width="200" Height="44" FontSize="14" FontWeight="Bold"
                    Background="#2A3048" Foreground="#9098B0" BorderThickness="0">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="10,5"
                          BorderBrush="#30506080" BorderThickness="1">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </DataTemplate>

    </ResourceDictionary>
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="390" Height="844">
      <!-- Layer 0: Main game canvas (tiles, ring, slash, particles, floating text, joystick) -->
      <local:DrawingSurface Width="390" Height="844" Commands="{Binding drawCommands}" />

      <!-- Layer 1: Character sprites -->
      <ItemsControl ItemsSource="{Binding characterSprites}" IsHitTestVisible="False"
                    ItemTemplate="{StaticResource SpriteItemTemplate}"
                    ItemContainerStyle="{StaticResource SpriteContainerStyle}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <Canvas Width="390" Height="844" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>

      <!-- Layer 1.5: Crit effect overlay (above character sprites, below HUD) -->
      <local:DrawingSurface Width="390" Height="844" Commands="{Binding critDrawCommands}" IsHitTestVisible="False" />

      <!-- Layer 2: HUD -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource HudTemplate}" IsHitTestVisible="True" />

      <!-- Layer 3: Pause Menu -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource PauseMenuTemplate}" />

      <!-- Layer 3.5: Upgrade Selection -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource UpgradeScreenTemplate}" />

      <!-- Layer 4: Title Screen -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource TitleScreenTemplate}" />

      <!-- Layer 5: Death Overlay -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource DeathOverlayTemplate}" IsHitTestVisible="False" />

      <!-- Layer 6: Death Screen -->
      <ContentControl Content="{Binding}" ContentTemplate="{StaticResource DeathScreenTemplate}" />
    </Grid>
  </Viewbox>
</Grid>
