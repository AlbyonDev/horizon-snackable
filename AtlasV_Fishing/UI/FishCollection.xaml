<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="1200" d:DesignHeight="2400">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Colors -->
        <SolidColorBrush x:Key="PanelBg" Color="#F0102030"/>
        <SolidColorBrush x:Key="CellBg" Color="#CC1A3050"/>
        <SolidColorBrush x:Key="CellCaughtBg" Color="#CC1E4060"/>
        <SolidColorBrush x:Key="GoldColor" Color="#FFFFD54F"/>
        <SolidColorBrush x:Key="TitleColor" Color="#FF4FC3F7"/>
        <SolidColorBrush x:Key="CloseColor" Color="#FFE88B8B"/>
        <SolidColorBrush x:Key="WhiteBorder" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BlackBorder" Color="#FF000000"/>

        <!-- Close Button Template (with X icon) -->
        <ControlTemplate x:Key="CloseBtnTemplate" TargetType="Button">
            <Border CornerRadius="28" Background="Transparent" RenderTransformOrigin="0.5,0.5" Width="160" Height="160">
                <Border.RenderTransform>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal"/>
                        <VisualState x:Name="MouseOver"/>
                        <VisualState x:Name="Pressed">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                 To="0.85" Duration="0:0:0.06"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                 To="0.85" Duration="0:0:0.06"/>
                            </Storyboard>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="160" Height="160">
                    <Ellipse Width="160" Height="160" Stroke="#FFFFFFFF" StrokeThickness="10">
                        <Ellipse.Fill>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF081828" Offset="1"/>
                                <GradientStop Offset="0" Color="#FF347AC0"/>
                            </LinearGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                    <Path Data="M 28,28 L 82,82 M 82,28 L 28,82" Margin="25,25,0,0" StrokeEndLineCap="Round" StrokeStartLineCap="Round" Stroke="#FFFFFFFF" StrokeThickness="15"/>
                </Grid>
            </Border>
        </ControlTemplate>

        <!-- Fish Cell Template -->
        <DataTemplate x:Key="FishCellTemplate">
            <Button Command="{Binding DataContext.events.onCellTapped, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                    CommandParameter="{Binding cellIndex}"
                    Width="450" Height="450" Margin="50,50,50,50">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="14" BorderBrush="#60FFFFFF" BorderThickness="1.5">
                            <Grid>
                                <!-- Uncaught: grey rectangle silhouette -->
                                <Border CornerRadius="14" Background="#40000000"
                                        Visibility="{Binding isUncaught, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <!-- Fish-shaped silhouette via OpacityMask -->
                                        <Rectangle Fill="#FF555555" Width="280" Height="280"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Margin="0,20,0,40">
                                            <Rectangle.OpacityMask>
                                                <ImageBrush ImageSource="{Binding fishIcon}" Stretch="Uniform"/>
                                            </Rectangle.OpacityMask>
                                        </Rectangle>
                                        <TextBlock Text="?" FontSize="56" FontWeight="Bold"
                                                   Foreground="#40FFFFFF"
                                                   HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                                   Margin="0,0,0,10"/>
                                    </Grid>
                                </Border>

                                <!-- Caught: full sprite + info -->
                                <Border CornerRadius="14"
                                        Visibility="{Binding isCaught, Converter={StaticResource BoolToVis}}">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#CC1E4060" Offset="0"/>
                                            <GradientStop Color="#CC102030" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Fish sprite -->
                                        <Border Grid.Row="0" Grid.RowSpan="2" Margin="50,50,50,50">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding fishIcon}" Stretch="Uniform"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding fishName}" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis" VerticalAlignment="Top" TextAlignment="Center" Stroke="#FF000000" FontSize="70" StrokeThickness="10"/>

                                        <!-- Info row -->
                                        <StackPanel Grid.Row="1" Margin="8,0,8,12">
                                            <Grid Margin="5,5,5,5">
                                                <TextBlock Text="{Binding quantity}" Foreground="#FFAADDFF" Margin="0,0,12,0" HorizontalAlignment="Left" FontSize="70"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Right">
                                                    <Image Source="Textures/gold_icon.png" VerticalAlignment="Center" Margin="0,0,5,0" Width="50" Height="50"/>
                                                    <TextBlock Text="{Binding goldPrice}" Foreground="#FFFFD54F" FontSize="70"/>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <!-- == COLLECTION OVERLAY == -->
        <Grid>
            <Grid.Visibility>
                <Binding Path="isCollectionVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Grid.Visibility>
            <!-- Semi-transparent backdrop -->
            <Border Background="#D0000000"/>

            <!-- Main panel -->
            <Border CornerRadius="24"
                    BorderBrush="#FF4FC3F7" BorderThickness="2" Margin="100,200,100,200">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="#F8081828" Offset="0"/>
                        <GradientStop Color="#F8102840" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid Grid.Row="0" Margin="24,20,24,10">
                        <TextBlock Text="FISH COLLECTION" FontWeight="Bold"
                                   Foreground="#FF4FC3F7" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Stroke="#FF000000" StrokeThickness="3" FontFamily="Anton" FontSize="120"/>
                        <!-- Close button -->
                        <Button HorizontalAlignment="Right" Template="{StaticResource CloseBtnTemplate}"
                                Command="{Binding events.onCloseCollection}" VerticalAlignment="Top" Width="160" Height="160" Margin="0,-80,-80,0"/>
                    </Grid>

                    <!-- Scrollable grid -->
                    <ScrollViewer Grid.Row="1" Margin="10,0,10,20"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding fishItems}"
                                      ItemTemplate="{StaticResource FishCellTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- == DETAIL OVERLAY == -->
        <Grid Visibility="{Binding isDetailVisible, Converter={StaticResource BoolToVis}}">
            <Button Command="{Binding events.onCloseDetail}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="#E8000000">
                            <TextBlock Text="{Binding detailFishName}" FontWeight="Bold" Foreground="#FF4FC3F7" HorizontalAlignment="Center" Stroke="#FF000000" StrokeThickness="4" FontFamily="Anton" FontSize="175" VerticalAlignment="Top" Margin="0,850,0,0"/>
                            <Border Margin="0,0,0,30" Width="1500" Height="1500">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding detailFishIcon}" Stretch="Uniform"/>
                                </Border.Background>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Grid>
</Page>
