<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="540" d:DesignHeight="960">

  <Viewbox Stretch="Uniform">
    <Grid Width="540" Height="960">
      <local:DrawingSurface Width="540" Height="960"
                            Commands="{Binding drawCommands}" />
    </Grid>
  </Viewbox>
</Page>
