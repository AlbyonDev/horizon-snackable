<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      Background="Transparent" d:DesignWidth="1080" d:DesignHeight="1920">

    <Page.Resources>
        <!-- ── Gradient brushes for Cast/Play button ── -->
        <LinearGradientBrush x:Key="CastNormalGradient" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FFFF8C33" Offset="0"/>
            <GradientStop Color="#FFFF5500" Offset="0.5"/>
            <GradientStop Color="#FFD44500" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="CastPressedGradient" StartPoint="0.5,0" EndPoint="0.5,1">
            <GradientStop Color="#FFD46A20" Offset="0"/>
            <GradientStop Color="#FFBB3A00" Offset="0.5"/>
            <GradientStop Color="#FFA03000" Offset="1"/>
        </LinearGradientBrush>

        <!-- ── Border brushes ── -->
        <SolidColorBrush x:Key="WhiteBorder" Color="#FFFFFFFF"/>
        <SolidColorBrush x:Key="BlackBorder" Color="#FF000000"/>

        <!-- ── Play Button Template (buzzer-style circular button) ── -->
        <ControlTemplate x:Key="CastButtonTemplate" TargetType="Button">
            <Grid Width="560" Height="600">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CastFaceTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="0" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase Springiness="3" Oscillations="1" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CastFaceScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase Springiness="3" Oscillations="1" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CastFaceScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="1" Duration="0:0:0.35">
                                    <DoubleAnimation.EasingFunction>
                                        <ElasticEase Springiness="3" Oscillations="1" EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CastInnerCircle"
                                                               Storyboard.TargetProperty="Background">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                            Value="{StaticResource CastNormalGradient}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualState>
                        <VisualState x:Name="MouseOver"/>
                        <VisualState x:Name="Pressed">
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="CastFaceTranslate"
                                                 Storyboard.TargetProperty="Y"
                                                 To="15" Duration="0:0:0.08">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CastFaceScale"
                                                 Storyboard.TargetProperty="ScaleX"
                                                 To="0.95" Duration="0:0:0.08">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetName="CastFaceScale"
                                                 Storyboard.TargetProperty="ScaleY"
                                                 To="0.95" Duration="0:0:0.08">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CastInnerCircle"
                                                               Storyboard.TargetProperty="Background">
                                    <DiscreteObjectKeyFrame KeyTime="0:0:0"
                                                            Value="{StaticResource CastPressedGradient}"/>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                        </VisualState>
                        <VisualState x:Name="Disabled"/>
                    </VisualStateGroup>
                </VisualStateManager.VisualStateGroups>

                <!-- Gradient shadow ellipse offset below -->
                <Border CornerRadius="280"
                        VerticalAlignment="Bottom"
                        Opacity="0.55" Background="#FF000000" Margin="10,0,10,40" Width="500" Height="500"/>

                <!-- Button face group (moves down + scales on press) -->
                <Grid x:Name="CastFaceGroup"
                      Width="540" Height="540"
                      VerticalAlignment="Top"
                      RenderTransformOrigin="0.5,0.5">
                    <Grid.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform x:Name="CastFaceScale" ScaleX="1" ScaleY="1"/>
                            <TranslateTransform x:Name="CastFaceTranslate" Y="0"/>
                        </TransformGroup>
                    </Grid.RenderTransform>

                    <!-- Outer white border ring -->
                    <Border CornerRadius="270"
                            Width="540" Height="540"
                            BorderBrush="{StaticResource WhiteBorder}"
                            BorderThickness="8"
                            Background="Transparent">

                        <!-- Inner black border ring -->
                        <Border CornerRadius="262"
                                BorderBrush="{StaticResource BlackBorder}"
                                BorderThickness="6"
                                Background="Transparent">

                        <!-- Light orange first ring -->
                        <Border CornerRadius="256"
                                Margin="2"
                                BorderBrush="Transparent"
                                BorderThickness="0" Background="#FFFFB366">

                            <!-- Inner vivid orange gradient circle with black border (buzzer) -->
                            <Border x:Name="CastInnerCircle"
                                    CornerRadius="240"
                                    Margin="18"
                                    BorderBrush="{StaticResource BlackBorder}"
                                    BorderThickness="2,2,2,2" Background="{StaticResource CastNormalGradient}">

                                <Grid>
                                    <!-- Text shadow (behind, offset) -->
                                    <TextBlock FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding Path=playButtonText, FallbackValue=Play}" FontSize="175" FontFamily="Bangers" Margin="0,6,0,0" Foreground="#96000000">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform Y="5" X="3"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>

                                    <!-- Label with stroke -->
                                    <TextBlock FontWeight="Bold"
                                               Foreground="White"
                                               Stroke="#FF000000"
                                               StrokeThickness="5"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Text="{Binding Path=playButtonText, FallbackValue=Play}" FontSize="175" FontFamily="Bangers"/>
                                </Grid>
                            </Border>
                        </Border>
                    </Border>
                    </Border>
                </Grid>
            </Grid>
        </ControlTemplate>
        <!-- ═══ Exit Animation Storyboard ═══ -->
        <Storyboard x:Key="TitleExitAnimation">
            <!-- Logo slides up off-screen -->
            <DoubleAnimation Storyboard.TargetName="LogoTranslate"
                             Storyboard.TargetProperty="Y"
                             From="0" To="-1500" Duration="0:0:0.45">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Play button scales down -->
            <DoubleAnimation Storyboard.TargetName="PlayBtnScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="PlayBtnScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <!-- Play button fades out -->
            <DoubleAnimation Storyboard.TargetName="PlayBtnPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.35">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Page.Resources>

    <!-- ═══ Main Layout ═══ -->
    <Grid>
        <!-- DataTrigger to start exit animation when isExiting = 'True' -->
        <b:Interaction.Triggers>
            <b:DataTrigger Binding="{Binding isExiting}" Value="True">
                <b:ControlStoryboardAction Storyboard="{StaticResource TitleExitAnimation}"
                                           ControlStoryboardOption="Play"/>
            </b:DataTrigger>
        </b:Interaction.Triggers>

        <!-- Fullscreen background image / Logo -->
        <Grid x:Name="LogoPanel">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="LogoTranslate" Y="0"/>
            </Grid.RenderTransform>
            <Image Source="Textures/FishingLegend_logo.png" VerticalAlignment="Top" Margin="100,300,100,300"/>
        </Grid>

        <!-- Play button using CastButtonTemplate -->
        <Grid x:Name="PlayBtnPanel" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <ScaleTransform x:Name="PlayBtnScale" ScaleX="1" ScaleY="1"/>
            </Grid.RenderTransform>
            <Button HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,600"
                    Template="{StaticResource CastButtonTemplate}"
                    Command="{Binding Path=events.onPlayPressed}"/>
        </Grid>
    </Grid>
</Page>
