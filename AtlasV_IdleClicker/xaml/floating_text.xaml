<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="TextShadow" Color="#80000000"/>

        <!-- ItemsPanel: Canvas for free positioning -->
        <ItemsPanelTemplate x:Key="FloatingTextPanelTemplate">
            <Canvas/>
        </ItemsPanelTemplate>

        <!-- ItemContainerStyle: position each item on the Canvas via bindings -->
        <Style x:Key="FloatingTextItemStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding Path=positionX}"/>
            <Setter Property="Canvas.Top" Value="{Binding Path=positionY}"/>
        </Style>

        <!-- DataTemplate: visual appearance of each floating text -->
        <DataTemplate x:Key="FloatingTextTemplate">
            <Grid Opacity="{Binding Path=opacity}" RenderTransformOrigin="0.5,0.5">
                <Grid.RenderTransform>
                    <ScaleTransform ScaleX="{Binding Path=scale}" ScaleY="{Binding Path=scale}"/>
                </Grid.RenderTransform>
                <!-- Shadow text -->
                <TextBlock Text="{Binding Path=text}" FontSize="48" FontWeight="Bold"
                           Foreground="{StaticResource TextShadow}" Margin="2,2,0,0" FontFamily="Bangers"/>
                <!-- Main colored text -->
                <TextBlock Text="{Binding Path=text}" FontSize="48" FontWeight="Bold"
                           Foreground="{Binding Path=color}" FontFamily="Bangers"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Viewbox Stretch="Uniform">
        <Canvas Width="800" Height="1200">
            <ItemsControl ItemsSource="{Binding Path=floatingTexts}"
                          ItemsPanel="{StaticResource FloatingTextPanelTemplate}"
                          ItemContainerStyle="{StaticResource FloatingTextItemStyle}"
                          ItemTemplate="{StaticResource FloatingTextTemplate}"/>
        </Canvas>
    </Viewbox>
</Page>
