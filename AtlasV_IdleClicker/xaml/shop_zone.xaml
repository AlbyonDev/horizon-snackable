<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920">

    <Grid.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Grid.Resources>

    <Viewbox VerticalAlignment="Center">
        <Grid Width="480" Height="850">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.15*"/>
                <RowDefinition Height="0.45*"/>
                <RowDefinition Height="0.4*"/>
            </Grid.RowDefinitions>
            <!-- Gradient background: transparent at top, fading to solid -->

            <Grid Grid.Row="2">
                <Border CornerRadius="0" Margin="0,-20,0,0">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="#001C242F" Offset="0"/>
                            <GradientStop Color="#FF1C242F" Offset="0.055059437"/>
                            <GradientStop Color="#FF1C242F" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <!-- Row 1: Scrollable shop items list -->
                <ScrollViewer Grid.Row="1"
                              VerticalAlignment="Bottom"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled" Padding="4,8,4,8" Margin="0,0,0,74">
                    <ItemsControl ItemsSource="{Binding Path=shopItems}"
                                  VerticalAlignment="Bottom" ItemTemplate="{DynamicResource UpgradeRow}"/>
                </ScrollViewer>

                <!-- Row 2: Fixed tab bar at bottom -->
                <Border Grid.Row="2" Height="74"
                        Background="#FF141C28" VerticalAlignment="Bottom">
                    <ItemsControl ItemsSource="{Binding Path=tabs}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center" ItemTemplate="{DynamicResource UpgradeTab}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Border>
            </Grid>
        </Grid>
    </Viewbox>
</Grid>
