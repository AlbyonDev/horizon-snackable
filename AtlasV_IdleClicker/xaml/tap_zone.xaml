<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920"
      Background="Black">

    <Grid.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Grid.Resources>

    <Viewbox VerticalAlignment="Center">
        <Grid Width="480" Height="850">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.15*"/>
                <RowDefinition Height="0.45*"/>
                <RowDefinition Height="0.4*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Top spacer (upgrade bar area, ~108px) -->

            <!-- All content in Row 1, below the upgrade bar -->
            <Grid Grid.Row="1">
            <!-- Layer 1: Full background image (mine cave scene) -->
            <Image Source="{Binding Path=backgroundImage}" Stretch="UniformToFill"/>

            <!-- Layer 2: Resource display at top center -->
            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,12,0,0"
                    Background="#99000000"
                    CornerRadius="16"
                    Padding="14,6,18,6">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Gem icon -->
                    <Border CornerRadius="4" Margin="0,0,8,0" Width="45" Height="45">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding Path=resourceIcon}" Stretch="Uniform"/>
                        </Border.Background>
                    </Border>
                    <!-- Gem count text -->
                    <TextBlock Text="{Binding Path=resourceText}"
                               FontWeight="Bold"
                               Foreground="#FFD700"
                               VerticalAlignment="Center"
                               Stroke="Black"
                               StrokeThickness="1" TextAlignment="Center" FontSize="40" FontFamily="Bangers"/>
                </StackPanel>
            </Border>

            <!-- Layer 2.5: TAP TO EARN label (hidden on tap, reappears after 5s inactivity) -->
            <TextBlock Text="TAP TO EARN"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Top"
                       Margin="0,80,0,0"
                       FontSize="48"
                       FontWeight="Bold"
                       FontFamily="Bangers"
                       Foreground="White"
                       Stroke="Black"
                       StrokeThickness="2"
                       Visibility="{Binding tapToEarnVisible, Converter={StaticResource BoolToVis}}"/>

            <!-- Layer 3: Gem deposit image with RenderTransform bindings -->
            <Border Width="180" Height="180"
                    HorizontalAlignment="Center"
                    RenderTransformOrigin="0.5,0.5" VerticalAlignment="Bottom" Margin="0,0,0,30">
                <Border.RenderTransform>
                    <TransformGroup>
                        <TranslateTransform X="{Binding Path=gemPositionX}"
                                            Y="{Binding Path=gemPositionY}"/>
                        <RotateTransform Angle="{Binding Path=gemRotation}"/>
                        <ScaleTransform ScaleX="{Binding Path=gemScale}"
                                        ScaleY="{Binding Path=gemScale}"/>
                        <!-- Animated layer on top: pop + tiny rocking on tap -->
                        <ScaleTransform x:Name="GemPop" ScaleX="1" ScaleY="1"/>
                        <RotateTransform x:Name="GemShake" Angle="0"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <b:Interaction.Triggers>
                    <b:PropertyChangedTrigger Binding="{Binding Path=gemAnimationTrigger}">
                        <b:ControlStoryboardAction>
                            <b:ControlStoryboardAction.Storyboard>
                                <Storyboard>
                                    <!-- Pop: squish then overshoot then settle -->
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GemPop" Storyboard.TargetProperty="ScaleX">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="0.973"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.13" Value="1.05">
                                            <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.4"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1">
                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GemPop" Storyboard.TargetProperty="ScaleY">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.05" Value="0.973"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.13" Value="1.05">
                                            <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.4"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.28" Value="1">
                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <!-- Subtle shake -->
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="GemShake" Storyboard.TargetProperty="Angle">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.06" Value="-1.67"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.14" Value="1.33"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="-0.67"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="0"/>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </b:ControlStoryboardAction.Storyboard>
                        </b:ControlStoryboardAction>
                    </b:PropertyChangedTrigger>
                </b:Interaction.Triggers>
                <Border.Background>
                    <ImageBrush ImageSource="{Binding Path=gemDepositImage}" Stretch="Uniform"/>
                </Border.Background>
            </Border>

            <!-- Layer 3.5: Crystal shard particles (rendered above gem deposit) -->
            <ItemsControl ItemsSource="{Binding Path=shards}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,30"
                          IsHitTestVisible="False"
                          Panel.ZIndex="2">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="480" Height="400"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="28" Height="28"
                                Opacity="{Binding Path=opacity}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding Path=rotation}"/>
                                    <ScaleTransform ScaleX="{Binding Path=scale}"
                                                    ScaleY="{Binding Path=scale}"/>
                                    <TranslateTransform X="{Binding Path=positionX}"
                                                        Y="{Binding Path=positionY}"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding Path=icon}" Stretch="Uniform"/>
                            </Border.Background>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="226"/>
                        <Setter Property="Canvas.Top" Value="300"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>

            <!-- Layer 3.5: Player tap pickaxe — outer border translates to tap position and flips
                 sprite horizontally for left-side taps; inner border owns the swing pivot. -->
            <Border Width="96" Height="96"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    Margin="60,0,0,40"
                    IsHitTestVisible="False"
                    Panel.ZIndex="1"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="{Binding Path=playerPickaxeFlip}" ScaleY="1"/>
                        <TranslateTransform X="{Binding Path=playerPickaxeX}"
                                            Y="{Binding Path=playerPickaxeY}"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <!-- Inner border owns the swing pivot.
                     Two triggers share the same target names but mirror the angle keyframes
                     so the strike always swings toward the center regardless of side. -->
                <Border Width="96" Height="96"
                        RenderTransformOrigin="0.5,0.9">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <RotateTransform x:Name="PlayerPickaxeSwing" Angle="20"/>
                            <ScaleTransform x:Name="PlayerPickaxePop" ScaleX="1" ScaleY="1"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <b:Interaction.Triggers>
                        <!-- Left tap (flip=-1, sprite already mirrored by outer ScaleX):
                             anim in sprite-local space → windup CW (+20) → strike CCW (-40) → follow-through (+45) → rest -->
                        <b:PropertyChangedTrigger Binding="{Binding Path=playerPickaxeTrigger}">
                            <b:ControlStoryboardAction>
                                <b:ControlStoryboardAction.Storyboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxeSwing" Storyboard.TargetProperty="Angle">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="20"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="-40">
                                                <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="45">
                                                <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="20">
                                                <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxePop" Storyboard.TargetProperty="ScaleX">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxePop" Storyboard.TargetProperty="ScaleY">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </b:ControlStoryboardAction.Storyboard>
                            </b:ControlStoryboardAction>
                        </b:PropertyChangedTrigger>
                        <!-- Right tap (flip=1, no mirror): same sprite-local swing but triggered separately -->
                        <b:PropertyChangedTrigger Binding="{Binding Path=playerPickaxeTriggerLeft}">
                            <b:ControlStoryboardAction>
                                <b:ControlStoryboardAction.Storyboard>
                                    <Storyboard>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxeSwing" Storyboard.TargetProperty="Angle">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="20"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="-40">
                                                <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="45">
                                                <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="20">
                                                <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></EasingDoubleKeyFrame.EasingFunction>
                                            </EasingDoubleKeyFrame>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxePop" Storyboard.TargetProperty="ScaleX">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="PlayerPickaxePop" Storyboard.TargetProperty="ScaleY">
                                            <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                            <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </b:ControlStoryboardAction.Storyboard>
                            </b:ControlStoryboardAction>
                        </b:PropertyChangedTrigger>
                    </b:Interaction.Triggers>
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding Path=playerPickaxeIcon}" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
            </Border>

            <!-- Layer 4: Cursors (auto-miners) — behind player pickaxe (ZIndex 0 < 1) -->
            <ItemsControl ItemsSource="{Binding Path=cursors}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"
                          Panel.ZIndex="0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Width="480" Height="486"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Outer: position + resting orientation + size scale only -->
                        <Border Width="64" Height="64" RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <TranslateTransform X="{Binding Path=positionX}" Y="{Binding Path=positionY}"/>
                                    <RotateTransform Angle="{Binding Path=rotation}"/>
                                    <ScaleTransform ScaleX="{Binding Path=scale}" ScaleY="{Binding Path=scale}"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <!-- Inner: swing pivot at handle base (0.5,0.9) + pop, same as player pickaxe -->
                            <Border Width="64" Height="64" RenderTransformOrigin="0.5,0.9">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <RotateTransform x:Name="CursorSwing" Angle="{Binding Path=swingWindup}"/>
                                        <ScaleTransform x:Name="CursorPop" ScaleX="1" ScaleY="1"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <b:Interaction.Triggers>
                                    <b:PropertyChangedTrigger Binding="{Binding Path=animationTrigger}">
                                        <b:ControlStoryboardAction>
                                            <b:ControlStoryboardAction.Storyboard>
                                                <Storyboard>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CursorSwing" Storyboard.TargetProperty="Angle">
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="{Binding Path=swingWindup}"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="{Binding Path=swingStrike}">
                                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseOut"/></EasingDoubleKeyFrame.EasingFunction>
                                                        </EasingDoubleKeyFrame>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="{Binding Path=swingWindup}">
                                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                                                        </EasingDoubleKeyFrame>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="{Binding Path=swingWindup}">
                                                            <EasingDoubleKeyFrame.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.3"/></EasingDoubleKeyFrame.EasingFunction>
                                                        </EasingDoubleKeyFrame>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CursorPop" Storyboard.TargetProperty="ScaleX">
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CursorPop" Storyboard.TargetProperty="ScaleY">
                                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.08" Value="0.9"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="1.15"/>
                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.34" Value="1"/>
                                                    </DoubleAnimationUsingKeyFrames>
                                                </Storyboard>
                                            </b:ControlStoryboardAction.Storyboard>
                                        </b:ControlStoryboardAction>
                                    </b:PropertyChangedTrigger>
                                </b:Interaction.Triggers>
                                <Image Stretch="Uniform" Source="{Binding Path=icon}"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform ScaleX="{Binding Path=flipX}" ScaleY="1"/>
                                    </Image.RenderTransform>
                                </Image>
                            </Border>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="208"/>
                        <Setter Property="Canvas.Top" Value="211"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </Grid>

            <!-- Bonus mini-gem (spans full 480×850 canvas so positions match PlayerTap coords). -->
            <Border Width="70" Height="70"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Panel.ZIndex="3"
                    Visibility="{Binding Path=bonusGemVisible, Converter={StaticResource BoolToVis}}"
                    RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <!-- Scale first (around the Border's own 0.5,0.5 origin) -->
                        <ScaleTransform x:Name="BonusGemPulse" ScaleX="1" ScaleY="1"/>
                        <!-- Then translate so the (X,Y) binding represents the center on the 480×850 canvas. -->
                        <TranslateTransform X="-35" Y="-35"/>
                        <TranslateTransform X="{Binding Path=bonusGemX}" Y="{Binding Path=bonusGemY}"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <b:Interaction.Triggers>
                    <b:PropertyChangedTrigger Binding="{Binding Path=bonusGemPulseTrigger}">
                        <b:ControlStoryboardAction>
                            <b:ControlStoryboardAction.Storyboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BonusGemPulse" Storyboard.TargetProperty="ScaleX">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.15">
                                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1">
                                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BonusGemPulse" Storyboard.TargetProperty="ScaleY">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="1.15">
                                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1">
                                            <EasingDoubleKeyFrame.EasingFunction><SineEase EasingMode="EaseInOut"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </b:ControlStoryboardAction.Storyboard>
                        </b:ControlStoryboardAction>
                    </b:PropertyChangedTrigger>
                    <b:PropertyChangedTrigger Binding="{Binding Path=bonusGemCollectTrigger}">
                        <b:ControlStoryboardAction>
                            <b:ControlStoryboardAction.Storyboard>
                                <Storyboard>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BonusGemPulse" Storyboard.TargetProperty="ScaleX">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.15"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetName="BonusGemPulse" Storyboard.TargetProperty="ScaleY">
                                        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1.15"/>
                                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="0">
                                            <EasingDoubleKeyFrame.EasingFunction><QuadraticEase EasingMode="EaseIn"/></EasingDoubleKeyFrame.EasingFunction>
                                        </EasingDoubleKeyFrame>
                                    </DoubleAnimationUsingKeyFrames>
                                </Storyboard>
                            </b:ControlStoryboardAction.Storyboard>
                        </b:ControlStoryboardAction>
                    </b:PropertyChangedTrigger>
                </b:Interaction.Triggers>
                <Border.Background>
                    <ImageBrush ImageSource="{Binding Path=bonusGemImage}" Stretch="Uniform"/>
                </Border.Background>
            </Border>
        </Grid>
    </Viewbox>
</Grid>
