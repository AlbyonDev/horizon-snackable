<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920"
      Background="Black">

    <Grid.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Grid.Resources>
    <Image Source="{Binding Path=backgroundImage}" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center"/>
    <Border>
        <Border.Background>
            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                <GradientStop Color="#AA000000" Offset="0"/>
                <GradientStop Color="#33000000" Offset="0.4"/>
                <GradientStop Color="#33000000" Offset="0.6"/>
                <GradientStop Color="#CC000000" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
    </Border>
    <Viewbox>
        <Grid Width="480" Height="850">
            <Grid>
                <Border HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,140,0,0" Width="450" Height="250" RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="{Binding logoScaleX}" ScaleY="{Binding logoScaleY}"/>
                            <TranslateTransform Y="{Binding logoTranslateY}"/>
                        </TransformGroup>
                    </Border.RenderTransform>
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding Path=titleImage}" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
                <Button Command="{Binding Path=events.onPlayClicked}" HorizontalAlignment="Center" Width="220" Height="70" FontSize="30" VerticalAlignment="Bottom" Margin="0,0,0,180">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ButtonBorder" Padding="0" CornerRadius="15,15,15,15">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                        <GradientStop Color="#FFD700" Offset="0"/>
                                        <GradientStop Color="#B8860B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="#FF000000"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>
                                    <Thickness>2</Thickness>
                                </Border.BorderThickness>
                                <TextBlock FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" FontSize="48" Stroke="#FF000000" StrokeThickness="4" Foreground="#FFE9E9E9" FontFamily="Bangers" Text="PLAY"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Viewbox>
    <Border Background="Black" Visibility="{Binding Path=fadeVisible, Converter={StaticResource BoolToVis}}" Opacity="{Binding Path=fadeOpacity}"/>
</Grid>
