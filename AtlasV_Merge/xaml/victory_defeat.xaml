<Grid Background="Transparent"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Victory hero card template -->
    <DataTemplate x:Key="VictoryHeroCardTemplate">
      <Grid Width="148" Height="220" Margin="4,0"
            RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
          <ScaleTransform ScaleX="{Binding cardScaleX}" ScaleY="{Binding cardScaleY}"/>
        </Grid.RenderTransform>

        <Border CornerRadius="12" Margin="-3"
                BorderThickness="3" BorderBrush="#FFD700"
                Opacity="{Binding glowOpacity}"/>

        <Border CornerRadius="9" BorderThickness="2" BorderBrush="#3A3A55">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#FF26263F"/>
              <GradientStop Offset="0.55" Color="#FF181828"/>
              <GradientStop Offset="1" Color="#FF0B0B16"/>
            </LinearGradientBrush>
          </Border.Background>

          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="22"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="18"/>
              <RowDefinition Height="22"/>
              <RowDefinition Height="18"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="7,7,0,0">
              <Border.Background>
                <SolidColorBrush Color="{Binding manaColorHex}" Opacity="0.85"/>
              </Border.Background>
              <TextBlock Text="{Binding heroName}" FontFamily="Bangers" FontSize="13"
                         Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                         noesis:Text.StrokeThickness="1.5">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
            </Border>

            <Image Grid.Row="1" Stretch="Uniform" Margin="6,3,6,3"
                   VerticalAlignment="Center" IsHitTestVisible="False">
              <Image.Source><Binding Path="texture"/></Image.Source>
            </Image>

            <TextBlock Grid.Row="2" Text="{Binding levelText}" FontFamily="Bangers" FontSize="12"
                       Foreground="#88FF88" HorizontalAlignment="Center" VerticalAlignment="Center"
                       noesis:Text.StrokeThickness="1">
              <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
            </TextBlock>

            <Grid Grid.Row="3" Margin="6,3,6,3">
              <Border CornerRadius="3" Background="#33000000" BorderBrush="#44FFFFFF" BorderThickness="1"/>
              <Rectangle Width="{Binding xpBarFillWidth}" HorizontalAlignment="Left"
                         RadiusX="3" RadiusY="3" Margin="2">
                <Rectangle.Fill>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Offset="0" Color="#FF00CCFF"/>
                    <GradientStop Offset="1" Color="#FF00FF88"/>
                  </LinearGradientBrush>
                </Rectangle.Fill>
              </Rectangle>
            </Grid>

            <TextBlock Grid.Row="4" Text="{Binding xpGainedText}" FontFamily="Bangers" FontSize="11"
                       Foreground="#AADDFF" HorizontalAlignment="Center" VerticalAlignment="Center"
                       noesis:Text.StrokeThickness="1">
              <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
            </TextBlock>
          </Grid>
        </Border>

        <!-- K.O. overlay -->
        <Border CornerRadius="9" Background="#BB06000E"
                Visibility="{Binding isDead, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="K.O." FontFamily="Bangers" FontSize="36"
                     Foreground="#FF4444" HorizontalAlignment="Center" VerticalAlignment="Center"
                     noesis:Text.StrokeThickness="2.5">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
        </Border>

        <!-- LEVEL UP! overlay with pop-in scale animation -->
        <Border CornerRadius="9" Background="#AA000010"
                Visibility="{Binding levelUpVisible, Converter={StaticResource BoolToVis}}"
                RenderTransformOrigin="0.5,0.5">
          <Border.RenderTransform>
            <ScaleTransform ScaleX="{Binding levelUpTextScale}" ScaleY="{Binding levelUpTextScale}"/>
          </Border.RenderTransform>
          <TextBlock Text="LEVEL UP!" FontFamily="Bangers" FontSize="22"
                     Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center"
                     noesis:Text.StrokeThickness="2.5">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
        </Border>
      </Grid>
    </DataTemplate>

    <!-- Defeat / Flee hero card template -->
    <DataTemplate x:Key="DefeatHeroCardTemplate">
      <Grid Width="140" Height="185" Margin="6,0">

        <Border CornerRadius="9" BorderThickness="2" BorderBrush="#442233"
                Opacity="{Binding cardOpacity}">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#FF1E0E0E"/>
              <GradientStop Offset="1" Color="#FF0A0606"/>
            </LinearGradientBrush>
          </Border.Background>

          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="22"/>
              <RowDefinition Height="*"/>
              <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" CornerRadius="7,7,0,0">
              <Border.Background>
                <SolidColorBrush Color="{Binding manaColorHex}" Opacity="0.75"/>
              </Border.Background>
              <TextBlock Text="{Binding heroName}" FontFamily="Bangers" FontSize="13"
                         Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                         noesis:Text.StrokeThickness="1.5">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
            </Border>

            <Image Grid.Row="1" Stretch="Uniform" Margin="6,4,6,4"
                   VerticalAlignment="Center" IsHitTestVisible="False">
              <Image.Source><Binding Path="texture"/></Image.Source>
            </Image>

            <Grid Grid.Row="2" Margin="6,3,6,4">
              <Border CornerRadius="3" Background="#33000000" BorderBrush="#44FFFFFF" BorderThickness="1"/>
              <Rectangle Width="{Binding hpFillWidth}" HorizontalAlignment="Left"
                         RadiusX="3" RadiusY="3" Margin="2">
                <Rectangle.Fill>
                  <SolidColorBrush Color="{Binding hpBarColor}"/>
                </Rectangle.Fill>
              </Rectangle>
              <TextBlock Text="{Binding hpText}" FontFamily="Bangers" FontSize="10"
                         Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                         noesis:Text.StrokeThickness="1">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
            </Grid>
          </Grid>
        </Border>

        <!-- K.O. overlay -->
        <Border CornerRadius="9" Background="#BB06000E"
                Visibility="{Binding isDead, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="K.O." FontFamily="Bangers" FontSize="36"
                     Foreground="#FF4444" HorizontalAlignment="Center" VerticalAlignment="Center"
                     noesis:Text.StrokeThickness="2.5">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
        </Border>
      </Grid>
    </DataTemplate>
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">

      <!-- Defeat / Flee result screen -->
      <Grid Visibility="{Binding resultScreenVisible, Converter={StaticResource BoolToVis}}">
        <Grid.Background>
          <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0" Color="#F2000000"/>
            <GradientStop Offset="1" Color="#F2150000"/>
          </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,70,0,0">
          <TextBlock Text="{Binding defeatTitle}" FontFamily="Bangers" FontSize="64"
                     HorizontalAlignment="Center"
                     noesis:Text.StrokeThickness="4">
            <TextBlock.Foreground>
              <SolidColorBrush Color="{Binding defeatTitleColor}"/>
            </TextBlock.Foreground>
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>

          <TextBlock Text="{Binding defeatSubtitle}" FontFamily="Bangers" FontSize="20"
                     Foreground="#AAAAAA" HorizontalAlignment="Center" Margin="0,4,0,0"
                     noesis:Text.StrokeThickness="1.5">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>

          <Rectangle Height="1" Width="320" HorizontalAlignment="Center" Fill="#44FFFFFF" Margin="0,14,0,14"/>

          <ItemsControl ItemsSource="{Binding defeatHeroes}"
                        ItemTemplate="{StaticResource DefeatHeroCardTemplate}"
                        HorizontalAlignment="Center">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal"/>
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
          </ItemsControl>
        </StackPanel>

        <TextBlock Text="{Binding defeatRoomsText}" FontFamily="Bangers" FontSize="18"
                   Foreground="#888888" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom" Margin="0,0,0,148"
                   noesis:Text.StrokeThickness="1.5">
          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
        </TextBlock>

        <Button Command="{Binding events.onReturnClicked}"
                Width="250" Height="64"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,60">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border CornerRadius="14" BorderThickness="2.5" BorderBrush="#CC3333">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF8B1A1A"/>
                    <GradientStop Offset="1" Color="#FF4A0A0A"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="RETURN" FontFamily="Bangers" FontSize="26"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="2">
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

      <!-- Victory / Room Reward overlay -->
      <Grid Visibility="{Binding roomRewardVisible, Converter={StaticResource BoolToVis}}"
            Background="#DD000000">

        <TextBlock Text="{Binding roomRewardTitle}" FontFamily="Bangers" FontSize="44"
                   Foreground="#FFD700" HorizontalAlignment="Center"
                   VerticalAlignment="Top" Margin="0,120,0,0"
                   noesis:Text.StrokeThickness="3">
          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
        </TextBlock>

        <ItemsControl ItemsSource="{Binding victoryHeroes}"
                      ItemTemplate="{StaticResource VictoryHeroCardTemplate}"
                      HorizontalAlignment="Center" VerticalAlignment="Center"
                      Margin="0,-40,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>

        <TextBlock Text="{Binding roomRewardGoldText}" FontFamily="Bangers" FontSize="22"
                   Foreground="#FFDD44" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom" Margin="0,0,0,130"
                   noesis:Text.StrokeThickness="2">
          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
        </TextBlock>

        <!-- Total gold display -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                    VerticalAlignment="Bottom" Margin="0,0,0,155">
          <Image Width="20" Height="20" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0" IsHitTestVisible="False">
            <Image.Source><Binding Path="goldIconTexture"/></Image.Source>
          </Image>
          <TextBlock Text="{Binding goldTotalText}" FontFamily="Bangers" FontSize="16" Foreground="#FFCC33" VerticalAlignment="Center"
                     noesis:Text.StrokeThickness="1.5">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
        </StackPanel>

        <TextBlock Text="{Binding roomRewardXpText}" FontFamily="Bangers" FontSize="16"
                   Foreground="#88CCFF" HorizontalAlignment="Center"
                   VerticalAlignment="Bottom" Margin="0,0,0,108"
                   noesis:Text.StrokeThickness="1.5">
          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
        </TextBlock>

        <!-- Continue button (mid-dungeon rooms) -->
        <Button Command="{Binding events.onDungeonContinueClicked}"
                Width="250" Height="64"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,40"
                Visibility="{Binding victoryContinueVisible, Converter={StaticResource BoolToVis}}">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border CornerRadius="14" BorderThickness="2.5" BorderBrush="#FFD700">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF4EC94E"/>
                    <GradientStop Offset="1" Color="#FF1E7832"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="CONTINUE" FontFamily="Bangers" FontSize="26"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="2">
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>

        <!-- Exit button (dungeon complete) -->
        <Button Command="{Binding events.onDungeonExitClicked}"
                Width="250" Height="64"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,40"
                Visibility="{Binding victoryExitVisible, Converter={StaticResource BoolToVis}}">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border CornerRadius="14" BorderThickness="2.5" BorderBrush="#FFD700">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF6A4EC9"/>
                    <GradientStop Offset="1" Color="#FF2A1878"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="EXIT DUNGEON" FontFamily="Bangers" FontSize="26"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="2">
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </Border>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

      <!-- Dungeon Complete overlay -->
      <Grid Visibility="{Binding dungeonCompleteVisible, Converter={StaticResource BoolToVis}}" Background="#DD000000">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
          <TextBlock Text="{Binding dungeonCompleteTitle}" FontFamily="Bangers" FontSize="36"
                     Foreground="#FFD700" HorizontalAlignment="Center"/>
          <TextBlock Text="DUNGEON CLEARED!" FontFamily="Bangers" FontSize="20"
                     Foreground="#88FF88" HorizontalAlignment="Center" Margin="0,8,0,0"/>
          <TextBlock Text="{Binding dungeonCompleteTotalXp}" FontSize="18"
                     Foreground="#88FF88" HorizontalAlignment="Center" Margin="0,16,0,0"/>
          <TextBlock Text="{Binding dungeonCompleteTotalGold}" FontSize="18"
                     Foreground="#FFDD44" HorizontalAlignment="Center" Margin="0,6,0,0"/>
          <TextBlock Text="{Binding dungeonCompleteNewLevel}" FontSize="18"
                     Foreground="#FF88FF" HorizontalAlignment="Center" Margin="0,6,0,0"/>
          <Button Content="EXIT DUNGEON" Command="{Binding events.onDungeonExitClicked}"
                  Width="220" Height="50" Margin="0,24,0,0" FontSize="18"
                  Background="#E94560" Foreground="White" BorderThickness="0"/>
        </StackPanel>
      </Grid>

    </Grid>
  </Viewbox>
</Grid>
