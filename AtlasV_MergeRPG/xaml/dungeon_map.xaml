<Grid Background="Transparent"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Offset="0" Color="#1A0A2E"/>
          <GradientStop Offset="0.5" Color="#0F0F2D"/>
          <GradientStop Offset="1" Color="#0A0A1A"/>
        </LinearGradientBrush>
      </Grid.Background>

      <!-- Dungeon title -->
      <TextBlock Text="{Binding dungeonMapTitle}" FontFamily="Bangers" FontSize="28"
                 Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Top"
                 Margin="0,30,0,0"/>

      <!-- Level/Gold info bar -->
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,68,0,0">
        <TextBlock Text="{Binding dungeonMapLevelText}" FontFamily="Bangers" FontSize="16"
                   Foreground="#88FF88" Margin="0,0,16,0"/>
        <TextBlock FontFamily="Bangers" FontSize="16" Foreground="#FFDD44">
          <Run Text="Gold: "/><Run Text="{Binding dungeonMapGoldText}"/>
        </TextBlock>
      </StackPanel>

      <!-- Room nodes vertical layout -->
      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-20,0,0">

        <!-- Room 1 Node -->
        <Grid Width="260" Height="120" Margin="0,8">
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.6"
                  Visibility="{Binding room1Completed, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#44FF44"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#1A3A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="✓" FontSize="32" Foreground="#44FF44" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room1Label}" FontFamily="Bangers" FontSize="18" Foreground="#88FF88" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3"
                  Visibility="{Binding room1Current, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#2A2A0A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="{Binding room1Label}" FontFamily="Bangers" FontSize="22" Foreground="#FFD700" HorizontalAlignment="Center"/>
              <TextBlock Text="⚔ READY" FontSize="14" Foreground="#FFDD88" HorizontalAlignment="Center" Margin="0,4,0,8"/>
              <Button Content="ENTER BATTLE" Command="{Binding events.onEnterBattleClicked}"
                      Width="160" Height="36" FontSize="14" FontWeight="Bold"
                      Background="#E94560" Foreground="White" BorderThickness="0"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.4"
                  Visibility="{Binding room1Locked, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#555555"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#1A1A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="🔒" FontSize="24" Foreground="#666666" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room1Label}" FontFamily="Bangers" FontSize="18" Foreground="#666666" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Path connector 1→2 -->
        <Border Width="4" Height="20" HorizontalAlignment="Center">
          <Border.Background><SolidColorBrush Color="#555555"/></Border.Background>
        </Border>

        <!-- Room 2 Node -->
        <Grid Width="260" Height="120" Margin="0,8">
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.6"
                  Visibility="{Binding room2Completed, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#44FF44"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#1A3A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="✓" FontSize="32" Foreground="#44FF44" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room2Label}" FontFamily="Bangers" FontSize="18" Foreground="#88FF88" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3"
                  Visibility="{Binding room2Current, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#FFD700"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#2A2A0A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="{Binding room2Label}" FontFamily="Bangers" FontSize="22" Foreground="#FFD700" HorizontalAlignment="Center"/>
              <TextBlock Text="⚔ READY" FontSize="14" Foreground="#FFDD88" HorizontalAlignment="Center" Margin="0,4,0,8"/>
              <Button Content="ENTER BATTLE" Command="{Binding events.onEnterBattleClicked}"
                      Width="160" Height="36" FontSize="14" FontWeight="Bold"
                      Background="#E94560" Foreground="White" BorderThickness="0"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.4"
                  Visibility="{Binding room2Locked, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#555555"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#1A1A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="🔒" FontSize="24" Foreground="#666666" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room2Label}" FontFamily="Bangers" FontSize="18" Foreground="#666666" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>

        <!-- Path connector 2→3 -->
        <Border Width="4" Height="20" HorizontalAlignment="Center">
          <Border.Background><SolidColorBrush Color="#555555"/></Border.Background>
        </Border>

        <!-- Room 3 (Boss) Node -->
        <Grid Width="260" Height="120" Margin="0,8">
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.6"
                  Visibility="{Binding room3Completed, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#FF4444"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#3A1A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="✓" FontSize="32" Foreground="#FF4444" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room3Label}" FontFamily="Bangers" FontSize="18" Foreground="#FF8888" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3"
                  Visibility="{Binding room3Current, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#FF4444"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#2A0A0A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="{Binding room3Label}" FontFamily="Bangers" FontSize="22" Foreground="#FF4444" HorizontalAlignment="Center"/>
              <TextBlock Text="💀 BOSS FIGHT" FontSize="14" Foreground="#FF8888" HorizontalAlignment="Center" Margin="0,4,0,8"/>
              <Button Content="ENTER BATTLE" Command="{Binding events.onEnterBattleClicked}"
                      Width="160" Height="36" FontSize="14" FontWeight="Bold"
                      Background="#CC2233" Foreground="White" BorderThickness="0"/>
            </StackPanel>
          </Border>
          <Border CornerRadius="12" BorderThickness="3" Opacity="0.4"
                  Visibility="{Binding room3Locked, Converter={StaticResource BoolToVis}}">
            <Border.BorderBrush><SolidColorBrush Color="#555555"/></Border.BorderBrush>
            <Border.Background><SolidColorBrush Color="#1A1A1A"/></Border.Background>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="🔒" FontSize="24" Foreground="#666666" HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding room3Label}" FontFamily="Bangers" FontSize="18" Foreground="#666666" HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>

      <!-- Flee Dungeon button (bottom) -->
      <Button Content="FLEE DUNGEON" Command="{Binding events.onFleeDungeonClicked}"
              Width="180" Height="44" FontSize="16"
              Background="#555555" Foreground="White" BorderThickness="0"
              VerticalAlignment="Bottom" HorizontalAlignment="Center"
              Margin="0,0,0,40"/>
    </Grid>
  </Viewbox>
</Grid>
