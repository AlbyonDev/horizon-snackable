<Grid Background="Black"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis"
  xmlns:noesis="clr-namespace:NoesisGUIExtensions"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />

    <!-- Hero card item — data-driven, one entry in viewModel.heroCards.
         Slot index 15 is a special buy-card (isBuyCard=true); the layout
         switches between hero and buy based on isHeroCard / isBuyCard. -->
    <DataTemplate x:Key="HeroCardItemTemplate">
      <Grid Width="148" Height="210" Margin="3,3,3,3"
            Visibility="{Binding isVisible, Converter={StaticResource BoolToVis}}">
        <Button Command="{Binding DataContext.events.onHeroCardClicked, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding parameter}"
                BorderThickness="0" Padding="0">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Grid>

                <!-- ===== Hero card layout (isHeroCard = true) ===== -->
                <Grid Visibility="{Binding isHeroCard, Converter={StaticResource BoolToVis}}">
                  <Border x:Name="GlowBorder" CornerRadius="11" Margin="-2"
                          BorderThickness="2" BorderBrush="#66FFD700" Opacity="0"/>
                  <Border x:Name="CardBorder" CornerRadius="9" BorderThickness="2" BorderBrush="#3A3A55">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#FF26263F"/>
                        <GradientStop Offset="0.55" Color="#FF181828"/>
                        <GradientStop Offset="1" Color="#FF0B0B16"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                      <Grid.RowDefinitions>
                        <RowDefinition Height="28"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="24"/>
                      </Grid.RowDefinitions>
                      <Border Grid.Row="0" CornerRadius="7,7,0,0">
                        <Border.Background>
                          <SolidColorBrush Color="{Binding manaColorHex}" Opacity="0.85"/>
                        </Border.Background>
                        <TextBlock Text="{Binding name}" FontFamily="Bangers" FontSize="15"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Border>
                      <Image Grid.Row="1" Stretch="Uniform" Margin="4,2,4,2"
                             VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="texture"/></Image.Source>
                      </Image>
                      <!-- Level badge (portrait, top-right) -->
                      <TextBlock Grid.Row="1" Text="{Binding levelText}" FontFamily="Bangers" FontSize="24"
                                 Foreground="#FFD700" HorizontalAlignment="Right" VerticalAlignment="Top"
                                 Margin="0,3,3,0" noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                      <!-- HP bar with text overlay -->
                      <Border Grid.Row="2" CornerRadius="0,0,7,7" Background="#CC0A0A1A">
                        <Grid Margin="4,2,4,2">
                          <Border CornerRadius="3" Background="#33000000" BorderBrush="#22FFFFFF" BorderThickness="1"/>
                          <Border CornerRadius="3" HorizontalAlignment="Left" Width="{Binding hpFillWidth}">
                            <Border.Background>
                              <SolidColorBrush Color="{Binding hpBarColor}"/>
                            </Border.Background>
                          </Border>
                          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="&#x2665; " FontSize="10" Foreground="#FF8899" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding hpText}" FontFamily="Bangers" FontSize="13"
                                       Foreground="White" VerticalAlignment="Center"
                                       noesis:Text.StrokeThickness="1">
                              <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                            </TextBlock>
                          </StackPanel>
                        </Grid>
                      </Border>
                      <!-- Healing overlay (visible when HP < max, outside K.O.) -->
                      <Border Grid.Row="1" VerticalAlignment="Bottom"
                              CornerRadius="4" Background="#CC000000" Padding="6,2" Margin="0,0,0,24"
                              Visibility="{Binding isHealing, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding recoveryText}" FontFamily="Bangers" FontSize="20"
                                   Foreground="#88FF88" HorizontalAlignment="Center"/>
                      </Border>
                      <!-- K.O. overlay -->
                      <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="9" Background="#BB06000E"
                              Visibility="{Binding isDead, Converter={StaticResource BoolToVis}}">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                          <TextBlock Text="K.O." FontFamily="Bangers" FontSize="28"
                                     Foreground="#FF4444" HorizontalAlignment="Center"
                                     noesis:Text.StrokeThickness="2">
                            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                          </TextBlock>
                        </StackPanel>
                      </Border>
                    </Grid>
                  </Border>
                </Grid>

                <!-- ===== Buy card layout (isBuyCard = true) ===== -->
                <Border x:Name="BuyBorder" CornerRadius="9" BorderThickness="2" BorderBrush="#66AABBFF"
                        Visibility="{Binding isBuyCard, Converter={StaticResource BoolToVis}}">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Offset="0" Color="#FF18182E"/>
                      <GradientStop Offset="1" Color="#FF0A0A1A"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="28"/>
                      <RowDefinition Height="*"/>
                      <RowDefinition Height="36"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="7,7,0,0" Background="#33AABBFF">
                      <TextBlock Text="NEW HERO" FontFamily="Bangers" FontSize="13"
                                 Foreground="#AACCFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Row="1" Text="+" FontFamily="Bangers" FontSize="80"
                               Foreground="#AACCFF" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="2">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000033"/></noesis:Text.Stroke>
                    </TextBlock>
                    <Border Grid.Row="2" CornerRadius="0,0,7,7" Background="#220A0A1A">
                      <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Paid: gold icon image + price amount -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding buyShowGoldIcon, Converter={StaticResource BoolToVis}}">
                          <Image Width="16" Height="16" Stretch="Uniform"
                                 VerticalAlignment="Center" Margin="0,0,4,0" IsHitTestVisible="False">
                            <Image.Source><Binding Path="goldIconTexture"/></Image.Source>
                          </Image>
                          <TextBlock Text="{Binding buyPriceText}" FontFamily="Bangers" FontSize="18"
                                     VerticalAlignment="Center" noesis:Text.StrokeThickness="1.5">
                            <TextBlock.Foreground>
                              <SolidColorBrush Color="{Binding buyPriceColorHex}"/>
                            </TextBlock.Foreground>
                            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                          </TextBlock>
                        </StackPanel>
                        <!-- Free: "FREE" label -->
                        <TextBlock Text="FREE" FontFamily="Bangers" FontSize="20"
                                   Foreground="#FF88FF88" HorizontalAlignment="Center"
                                   Visibility="{Binding buyIsFree, Converter={StaticResource BoolToVis}}"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF003300"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Grid>
                    </Border>
                  </Grid>
                </Border>

              </Grid>
              <ControlTemplate.Triggers>
                <DataTrigger Binding="{Binding inRoster}" Value="True">
                  <Setter TargetName="CardBorder" Property="BorderBrush" Value="#FFFFD700"/>
                  <Setter TargetName="GlowBorder" Property="Opacity" Value="1"/>
                </DataTrigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="CardBorder" Property="Opacity" Value="0.75"/>
                  <Setter TargetName="BuyBorder" Property="Opacity" Value="0.7"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
        <!-- Info button overlay — only visible on hero cards -->
        <Button Command="{Binding DataContext.events.onHeroCardInfoClicked, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                CommandParameter="{Binding parameter}"
                Width="26" Height="26" HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="4,4,0,0" BorderThickness="0" Padding="0"
                Visibility="{Binding isHeroCard, Converter={StaticResource BoolToVis}}">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border x:Name="IBg" CornerRadius="13" Background="#CC1A1D2E"
                      BorderBrush="#88AABBFF" BorderThickness="1">
                <TextBlock Text="i" FontFamily="Roboto" FontSize="15"
                           Foreground="#AACCFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="IBg" Property="Background" Value="#FFAACCFF"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>
    </DataTemplate>

    <!-- Roster slot item — empty/occupied dual layout driven by `occupied`. -->
    <DataTemplate x:Key="RosterSlotItemTemplate">
      <Button Command="{Binding DataContext.events.onRosterSlotClicked, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
              CommandParameter="{Binding parameter}"
              Width="135" Height="195" Margin="8,0" BorderThickness="0" Padding="0">
        <Button.Template>
          <ControlTemplate TargetType="Button">
            <Grid>
              <Border x:Name="EmptyBg" CornerRadius="10" BorderThickness="2" BorderBrush="#44556677"
                      Background="#1814242E">
                <TextBlock Text="EMPTY" FontFamily="Bangers" FontSize="11" Foreground="#7799AABB"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <Border x:Name="OccupiedBg" CornerRadius="10" BorderThickness="2" BorderBrush="#FFFFD700"
                      Visibility="{Binding occupied, Converter={StaticResource BoolToVis}}">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF2A2A48"/>
                    <GradientStop Offset="1" Color="#FF12122A"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="18"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" CornerRadius="8,8,0,0">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding manaColorHex}" Opacity="0.85"/>
                    </Border.Background>
                    <TextBlock Text="{Binding name}" FontFamily="Bangers" FontSize="12"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="1.5">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                    </TextBlock>
                  </Border>
                  <Image Grid.Row="1" Stretch="Uniform" Margin="4,2,4,2"
                         VerticalAlignment="Center" IsHitTestVisible="False">
                    <Image.Source><Binding Path="texture"/></Image.Source>
                  </Image>
                  <!-- Level badge (portrait, top-right) -->
                  <TextBlock Grid.Row="1" Text="{Binding levelText}" FontFamily="Bangers" FontSize="18"
                             Foreground="#FFD700" HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,3,3,0" noesis:Text.StrokeThickness="1.5">
                    <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                  </TextBlock>
                  <!-- HP bar with text overlay -->
                  <Border Grid.Row="2" CornerRadius="0,0,8,8" Background="#CC0A0A1A">
                    <Grid Margin="4,2,4,2">
                      <Border CornerRadius="3" Background="#33000000" BorderBrush="#22FFFFFF" BorderThickness="1"/>
                      <Border CornerRadius="3" HorizontalAlignment="Left" Width="{Binding hpFillWidth}">
                        <Border.Background>
                          <SolidColorBrush Color="{Binding hpBarColor}"/>
                        </Border.Background>
                      </Border>
                      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#x2665; " FontSize="9" Foreground="#FF8899" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding hpText}" FontFamily="Bangers" FontSize="11"
                                   Foreground="White" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </StackPanel>
                    </Grid>
                  </Border>
                  <!-- K.O. overlay -->
                  <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="10" Background="#BB06000E"
                          Visibility="{Binding isDead, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                      <TextBlock Text="K.O." FontFamily="Bangers" FontSize="28"
                                 Foreground="#FF4444" HorizontalAlignment="Center"
                                 noesis:Text.StrokeThickness="2">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                  </Border>
                </Grid>
              </Border>
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="EmptyBg" Property="Opacity" Value="0.75"/>
                <Setter TargetName="OccupiedBg" Property="Opacity" Value="0.75"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Button.Template>
      </Button>
    </DataTemplate>
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="850">
      <Grid.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Offset="0" Color="#FF1A0A2E"/>
          <GradientStop Offset="0.45" Color="#FF120A28"/>
          <GradientStop Offset="1" Color="#FF06060F"/>
        </LinearGradientBrush>
      </Grid.Background>

      <Grid.RowDefinitions>
        <RowDefinition Height="80"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="250"/>
        <RowDefinition Height="74"/>
      </Grid.RowDefinitions>

      <!-- Row 0: Title bar + Back button + subtitle -->
      <Grid Grid.Row="0">
        <Border CornerRadius="0,0,0,0" Background="#220A0A1A"/>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Bottom">
          <TextBlock Text="HERO COLLECTION" FontFamily="Bangers" FontSize="28"
                     Foreground="#FFD700" HorizontalAlignment="Center"
                     noesis:Text.StrokeThickness="2">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
          <TextBlock Text="Tap a card to equip &#x2022; Tap (i) for stats &#x2022; Tap a team slot to remove"
                     Foreground="#AAAACC"
                     HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Gold counter (top-right) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
          <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,4,0" IsHitTestVisible="False">
            <Image.Source><Binding Path="goldIconTexture"/></Image.Source>
          </Image>
          <TextBlock Text="{Binding goldText}" FontFamily="Bangers" Foreground="#FFD700" VerticalAlignment="Center"
                     noesis:Text.StrokeThickness="1.5" FontSize="30">
            <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
          </TextBlock>
        </StackPanel>
      </Grid>

      <!-- Row 1: Hero collection grid — slot 15 in the pool is the buy card -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                    Margin="6,4,6,4" VerticalAlignment="Center">
        <ItemsControl ItemsSource="{Binding heroCards}"
                      ItemTemplate="{StaticResource HeroCardItemTemplate}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <WrapPanel Width="470" HorizontalAlignment="Center"/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>

      <!-- Row 2: Roster Slots (3 fixed slots) -->
      <Grid Grid.Row="2" Margin="0,4,0,8" Grid.RowSpan="2">
        <Border CornerRadius="12" BorderThickness="2">
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#FF15152A"/>
              <GradientStop Offset="1" Color="#FF08081A"/>
            </LinearGradientBrush>
          </Border.Background>
        </Border>
        <Grid Margin="10,8,10,82">
          <Grid.RowDefinitions>
            <RowDefinition Height="24"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="&#x2694;" FontSize="14" Foreground="#FFD700" Margin="0,0,6,0" VerticalAlignment="Center"/>
            <TextBlock Text="YOUR TEAM" FontFamily="Bangers" FontSize="17"
                       Foreground="#FFD700" VerticalAlignment="Center"
                       noesis:Text.StrokeThickness="1.5">
              <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
            </TextBlock>
            <TextBlock Text="&#x2694;" FontSize="14" Foreground="#FFD700" Margin="6,0,0,0" VerticalAlignment="Center"/>
          </StackPanel>
          <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ItemsControl ItemsSource="{Binding rosterSlots}"
                          ItemTemplate="{StaticResource RosterSlotItemTemplate}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
            </ItemsControl>
          </StackPanel>
        </Grid>
      </Grid>

      <!-- Row 3: Enter Dungeon button -->
      <Grid Grid.Row="3" Margin="10,0,10,10">
        <Button Command="{Binding events.onRosterEnterDungeonClicked}"
                IsEnabled="{Binding rosterCanEnterDungeon}"
                BorderThickness="0" Padding="0" Height="60">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border CornerRadius="10" BorderBrush="#FFD700" BorderThickness="2">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Offset="0" Color="#44AA44"/>
                    <GradientStop Offset="1" Color="#226622"/>
                  </LinearGradientBrush>
                </Border.Background>
                <TextBlock Text="ENTER DUNGEON" FontFamily="Bangers" FontSize="24"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                  <Setter Property="Opacity" Value="0.4"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Button.Template>
        </Button>
      </Grid>

      <!-- Buy Popup Overlay (fullscreen, spans all rows) -->
      <Grid Grid.Row="0" Grid.RowSpan="4"
            Visibility="{Binding buyPopupVisible, Converter={StaticResource BoolToVis}}" d:IsHidden="True">
        <Border Background="#DD0A0818"/>

        <!-- Popup panel -->
        <Grid Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border CornerRadius="14" BorderThickness="2">
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF5588FF"/>
                <GradientStop Offset="0.5" Color="#FF2244AA"/>
                <GradientStop Offset="1" Color="#FF5588FF"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FF1A1D2E"/>
                <GradientStop Offset="1" Color="#FF0A0A1A"/>
              </LinearGradientBrush>
            </Border.Background>
            <Grid>

            <!-- ===== Confirm phase ===== -->
            <StackPanel Margin="24,24,24,24"
                        Visibility="{Binding buyConfirmVisible, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="NEW HERO" FontFamily="Bangers" FontSize="30"
                         Foreground="#AACCFF" HorizontalAlignment="Center"
                         noesis:Text.StrokeThickness="2">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
              <TextBlock Text="A random undiscovered hero will join your collection."
                         FontSize="13" Foreground="#BBBBCC" HorizontalAlignment="Center"
                         TextWrapping="Wrap" Margin="0,10,0,0" TextAlignment="Center"/>
              <!-- Price row -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,22">
                <Image Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0" IsHitTestVisible="False">
                  <Image.Source><Binding Path="goldIconTexture"/></Image.Source>
                </Image>
                <TextBlock Text="{Binding buyConfirmPriceText}" FontFamily="Bangers" FontSize="28"
                           VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="1.5">
                  <TextBlock.Foreground>
                    <SolidColorBrush Color="{Binding buyPriceColorHex}"/>
                  </TextBlock.Foreground>
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </StackPanel>
              <!-- YES / NO buttons -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding events.onBuyConfirmYes}"
                        IsEnabled="{Binding buyCanAfford}"
                        Width="120" Height="46" Margin="8,0" BorderThickness="0" Padding="0">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="YesBg" CornerRadius="8" BorderBrush="#FF44AA44" BorderThickness="2">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#FF44AA44"/>
                            <GradientStop Offset="1" Color="#FF226622"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="YES" FontFamily="Bangers" FontSize="22"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="YesBg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
                <Button Command="{Binding events.onBuyConfirmNo}"
                        Width="120" Height="46" Margin="8,0" BorderThickness="0" Padding="0">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="NoBg" CornerRadius="8" BorderBrush="#FFAA4444" BorderThickness="2">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#FFAA4444"/>
                            <GradientStop Offset="1" Color="#FF662222"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="NO" FontFamily="Bangers" FontSize="22"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="NoBg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
              </StackPanel>
            </StackPanel>

            <!-- ===== Roll phase ===== -->
            <StackPanel Margin="24,28,24,28"
                        Visibility="{Binding buyRollVisible, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="DISCOVERING..." FontFamily="Bangers" FontSize="26"
                         Foreground="#AACCFF" HorizontalAlignment="Center" Margin="0,0,0,16"
                         noesis:Text.StrokeThickness="2">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
              <!-- Cycling hero card -->
              <Border CornerRadius="9" BorderThickness="3" BorderBrush="#88AACCFF"
                      Width="160" HorizontalAlignment="Center">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF1E1E38"/>
                    <GradientStop Offset="1" Color="#FF0C0C20"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="160"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" CornerRadius="7,7,0,0">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding buyRollHeroManaColor}" Opacity="0.85"/>
                    </Border.Background>
                    <TextBlock Text="{Binding buyRollHeroName}" FontFamily="Bangers" FontSize="16"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="1.5">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                    </TextBlock>
                  </Border>
                  <Image Grid.Row="1" Stretch="Uniform" Margin="6">
                    <Image.Source><Binding Path="buyRollHeroTexture"/></Image.Source>
                  </Image>
                </Grid>
              </Border>
            </StackPanel>

            <!-- ===== Result phase ===== -->
            <StackPanel Margin="24,24,24,24"
                        Visibility="{Binding buyResultVisible, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="HERO UNLOCKED!" FontFamily="Bangers" FontSize="28"
                         Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,0,0,14"
                         noesis:Text.StrokeThickness="2">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
              <!-- Hero card preview -->
              <Border CornerRadius="9" BorderThickness="3" Width="160" HorizontalAlignment="Center"
                      Margin="0,0,0,16">
                <Border.BorderBrush>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#FFFFD700"/>
                    <GradientStop Offset="1" Color="#FFAA7700"/>
                  </LinearGradientBrush>
                </Border.BorderBrush>
                <Border.Background>
                  <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Offset="0" Color="#FF22223A"/>
                    <GradientStop Offset="1" Color="#FF0D0D22"/>
                  </LinearGradientBrush>
                </Border.Background>
                <Grid>
                  <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="160"/>
                    <RowDefinition Height="22"/>
                  </Grid.RowDefinitions>
                  <Border Grid.Row="0" CornerRadius="7,7,0,0">
                    <Border.Background>
                      <SolidColorBrush Color="{Binding buyResultHeroManaColor}" Opacity="0.85"/>
                    </Border.Background>
                    <TextBlock Text="{Binding buyResultHeroName}" FontFamily="Bangers" FontSize="16"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="1.5">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                    </TextBlock>
                  </Border>
                  <Image Grid.Row="1" Stretch="Uniform" Margin="6">
                    <Image.Source><Binding Path="buyResultHeroTexture"/></Image.Source>
                  </Image>
                  <Border Grid.Row="2" CornerRadius="0,0,7,7" Background="#220A0A1A">
                    <TextBlock Text="Lv.1" FontFamily="Bangers" FontSize="13"
                               Foreground="#FFD700" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </Grid>
              </Border>
              <!-- Collect button -->
              <Button Command="{Binding events.onBuyResultClose}"
                      Height="50" BorderThickness="0" Padding="0">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border x:Name="CollectBg" CornerRadius="8" BorderBrush="#FFFFD700" BorderThickness="2">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                          <GradientStop Offset="0" Color="#FFAA7700"/>
                          <GradientStop Offset="1" Color="#FF664400"/>
                        </LinearGradientBrush>
                      </Border.Background>
                      <TextBlock Text="COLLECT!" FontFamily="Bangers" FontSize="24"
                                 Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="CollectBg" Property="Opacity" Value="0.7"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </StackPanel>

            </Grid>
          </Border>
        </Grid>
      </Grid>

      <!-- Heal Popup Overlay (fullscreen, spans all rows) -->
      <Grid Grid.Row="0" Grid.RowSpan="4"
            Visibility="{Binding healPopupVisible, Converter={StaticResource BoolToVis}}" d:IsHidden="True">
        <Border Background="#DD0A0818"/>
        <Grid Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border CornerRadius="14" BorderThickness="2">
            <Border.BorderBrush>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF55FF88"/>
                <GradientStop Offset="0.5" Color="#FF228844"/>
                <GradientStop Offset="1" Color="#FF55FF88"/>
              </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FF1A1D2E"/>
                <GradientStop Offset="1" Color="#FF0A0A1A"/>
              </LinearGradientBrush>
            </Border.Background>
            <StackPanel Margin="24,24,24,24">
              <TextBlock Text="HEAL HERO" FontFamily="Bangers" FontSize="30"
                         Foreground="#55FF88" HorizontalAlignment="Center"
                         noesis:Text.StrokeThickness="2">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
              <TextBlock Text="{Binding healHeroName}" FontFamily="Bangers" FontSize="22"
                         Foreground="White" HorizontalAlignment="Center" Margin="0,8,0,0"
                         noesis:Text.StrokeThickness="1.5">
                <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
              </TextBlock>
              <TextBlock Text="Restore to full HP" FontSize="13" Foreground="#BBBBCC"
                         HorizontalAlignment="Center" Margin="0,8,0,0"/>
              <!-- Price row -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,18,0,22">
                <Image Width="28" Height="28" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0" IsHitTestVisible="False">
                  <Image.Source><Binding Path="goldIconTexture"/></Image.Source>
                </Image>
                <TextBlock Text="{Binding healConfirmPriceText}" FontFamily="Bangers" FontSize="28"
                           VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="1.5">
                  <TextBlock.Foreground>
                    <SolidColorBrush Color="{Binding healPriceColorHex}"/>
                  </TextBlock.Foreground>
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </StackPanel>
              <!-- YES / NO buttons -->
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Command="{Binding events.onHealConfirmYes}"
                        IsEnabled="{Binding healCanAfford}"
                        Width="120" Height="46" Margin="8,0" BorderThickness="0" Padding="0">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="HealYesBg" CornerRadius="8" BorderBrush="#FF44AA44" BorderThickness="2">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#FF44AA44"/>
                            <GradientStop Offset="1" Color="#FF226622"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="YES" FontFamily="Bangers" FontSize="22"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                          <Setter Property="Opacity" Value="0.35"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="HealYesBg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
                <Button Command="{Binding events.onHealConfirmNo}"
                        Width="120" Height="46" Margin="8,0" BorderThickness="0" Padding="0">
                  <Button.Template>
                    <ControlTemplate TargetType="Button">
                      <Border x:Name="HealNoBg" CornerRadius="8" BorderBrush="#FFAA4444" BorderThickness="2">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Offset="0" Color="#FFAA4444"/>
                            <GradientStop Offset="1" Color="#FF662222"/>
                          </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="NO" FontFamily="Bangers" FontSize="22"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   noesis:Text.StrokeThickness="1.5">
                          <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                        </TextBlock>
                      </Border>
                      <ControlTemplate.Triggers>
                        <Trigger Property="IsPressed" Value="True">
                          <Setter TargetName="HealNoBg" Property="Opacity" Value="0.7"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Button.Template>
                </Button>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>

      <!-- Detail Overlay (fullscreen, spans all rows) -->
      <Grid Grid.Row="0" Grid.RowSpan="4"
            Visibility="{Binding detailOverlayVisible, Converter={StaticResource BoolToVis}}">
        <!-- Semi-transparent tap-to-close background -->
        <Button Command="{Binding events.onDetailCloseClicked}" BorderThickness="0" Padding="0">
          <Button.Template>
            <ControlTemplate TargetType="Button">
              <Border Background="#CC1A1028"/>
            </ControlTemplate>
          </Button.Template>
        </Button>

        <!-- Detail panel (centered card) -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
          <Border CornerRadius="14" BorderThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center">
          <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
              <GradientStop Offset="0" Color="#FFFFD700"/>
              <GradientStop Offset="0.5" Color="#FFAA8800"/>
              <GradientStop Offset="1" Color="#FFFFD700"/>
            </LinearGradientBrush>
          </Border.BorderBrush>
          <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
              <GradientStop Offset="0" Color="#FF1A1D2E"/>
              <GradientStop Offset="1" Color="#FF0A0A1A"/>
            </LinearGradientBrush>
          </Border.Background>

          <Grid HorizontalAlignment="Center">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="180"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>

              <!-- Row 0: Name banner with colored background -->
              <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="0,6">
                <Border.Background>
                  <SolidColorBrush Color="{Binding detailManaColorHex}" Opacity="0.85"/>
                </Border.Background>
                <TextBlock Text="{Binding detailName}" FontFamily="Bangers" FontSize="22"
                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                           noesis:Text.StrokeThickness="1.5">
                  <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                </TextBlock>
              </Border>

              <!-- Row 1: Portrait image -->
              <Border Grid.Row="1" CornerRadius="0,0,10,10" Background="#0A0A1A">
                <Image Stretch="Uniform" Margin="10" IsHitTestVisible="False">
                  <Image.Source><Binding Path="detailTexture"/></Image.Source>
                </Image>
              </Border>

              <!-- Row 2: (removed big level text - level now shown in XP tab) -->

              <!-- Row 3: HP text + recovery countdown -->
              <StackPanel Grid.Row="3" Margin="0,6,0,0" HorizontalAlignment="Center">
                <!-- HP text only (no bar) -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                  <TextBlock Text="&#x2665; " FontSize="16" Foreground="#FF8899" VerticalAlignment="Center"/>
                  <TextBlock Text="HP: " FontFamily="Bangers" FontSize="16" Foreground="#EEEEEE" VerticalAlignment="Center"/>
                  <TextBlock Text="{Binding detailHpText}" FontFamily="Bangers" FontSize="18"
                             VerticalAlignment="Center"
                             noesis:Text.StrokeThickness="1">
                    <TextBlock.Foreground>
                      <SolidColorBrush Color="{Binding detailHpColor}"/>
                    </TextBlock.Foreground>
                    <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                  </TextBlock>
                </StackPanel>
                <!-- Recovery countdown (3x size) -->
                <TextBlock Text="{Binding detailRecoveryText}" FontFamily="Bangers" FontSize="33"
                           HorizontalAlignment="Center" Margin="0,4,0,4">
                  <TextBlock.Foreground>
                    <SolidColorBrush Color="{Binding detailRecoveryColor}"/>
                  </TextBlock.Foreground>
                </TextBlock>
                <!-- XP row: level tab + bar -->
                <StackPanel Orientation="Horizontal" Margin="5,5,5,5">
                  <Border Width="52" Height="26" CornerRadius="4,0,0,4"
                          Background="#220A1A1A" BorderBrush="#8844BBCC" BorderThickness="1,1,0,1">
                    <TextBlock Text="{Binding detailLevelText}" FontFamily="Bangers" FontSize="18" Foreground="#44BBCC"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <Grid Width="280" Height="26">
                    <Border CornerRadius="0,4,4,0" Background="#22000000" BorderBrush="#33FFFFFF" BorderThickness="0,1,1,1"/>
                    <Border CornerRadius="0,4,4,0" HorizontalAlignment="Left" Width="{Binding detailXpFillWidth}">
                      <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                          <GradientStop Offset="0" Color="#FF3DAAAA"/>
                          <GradientStop Offset="1" Color="#FF3DDD77"/>
                        </LinearGradientBrush>
                      </Border.Background>
                    </Border>
                    <TextBlock Text="{Binding detailXpText}" FontFamily="Bangers" FontSize="18"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="1">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </StackPanel>

              <!-- Row 4: Power section with background -->
              <Border Grid.Row="4" Margin="0,10,0,0" CornerRadius="8" Background="#CC0A0A1A" Padding="10,14">
                <Grid>
                  <!-- Cost: gem sprite with number (top-left) -->
                  <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Width="28" Height="28">
                    <Image Width="28" Height="28" Stretch="Uniform" IsHitTestVisible="False">
                      <Image.Source><Binding Path="detailCostGemTexture"/></Image.Source>
                    </Image>
                    <TextBlock Text="{Binding detailManaCost}" FontFamily="Bangers" FontSize="13"
                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"
                               noesis:Text.StrokeThickness="1.5">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                    </TextBlock>
                  </Grid>
                  <!-- Power name + description (centered) -->
                  <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="36,0,0,0" Width="250">
                    <TextBlock Text="{Binding detailPowerName}" FontFamily="Bangers" FontSize="18"
                               HorizontalAlignment="Center"
                               noesis:Text.StrokeThickness="1.5">
                      <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      <TextBlock.Foreground>
                        <SolidColorBrush Color="{Binding detailManaColorHex}"/>
                      </TextBlock.Foreground>
                    </TextBlock>
                    <TextBlock Text="{Binding detailPowerDesc}" FontSize="12" Foreground="#BBBBBB"
                               TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                  </StackPanel>
                </Grid>
              </Border>

              <!-- Row 5: Damages footer banner (full-width, top border only) -->
              <Border Grid.Row="5" Margin="0,0,0,0" CornerRadius="0,0,12,12" BorderThickness="0,2,0,0"
                      BorderBrush="#55FFD700" VerticalAlignment="Bottom">
                <Border.Background>
                  <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Offset="0" Color="#FF1F1F33"/>
                    <GradientStop Offset="1" Color="#FF0A0A18"/>
                  </LinearGradientBrush>
                </Border.Background>
                <StackPanel Orientation="Vertical" Margin="10,8,10,10">
                  <TextBlock Text="Damages" FontFamily="Bangers" FontSize="16"
                             Foreground="#FFD700" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                  <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <!-- Red -->
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                      <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="redGemTexture"/></Image.Source>
                      </Image>
                      <TextBlock Text="{Binding detailDmgRed}" FontFamily="Bangers" FontSize="20"
                                 Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                    <!-- Blue -->
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                      <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="blueGemTexture"/></Image.Source>
                      </Image>
                      <TextBlock Text="{Binding detailDmgBlue}" FontFamily="Bangers" FontSize="20"
                                 Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                    <!-- Green -->
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                      <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="greenGemTexture"/></Image.Source>
                      </Image>
                      <TextBlock Text="{Binding detailDmgGreen}" FontFamily="Bangers" FontSize="20"
                                 Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                    <!-- Yellow -->
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                      <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="yellowGemTexture"/></Image.Source>
                      </Image>
                      <TextBlock Text="{Binding detailDmgYellow}" FontFamily="Bangers" FontSize="20"
                                 Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                    <!-- Purple -->
                    <StackPanel Orientation="Horizontal" Margin="5,0">
                      <Image Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" IsHitTestVisible="False">
                        <Image.Source><Binding Path="purpleGemTexture"/></Image.Source>
                      </Image>
                      <TextBlock Text="{Binding detailDmgPurple}" FontFamily="Bangers" FontSize="20"
                                 Foreground="White" VerticalAlignment="Center" Margin="4,0,0,0"
                                 noesis:Text.StrokeThickness="1.5">
                        <noesis:Text.Stroke><SolidColorBrush Color="#FF000000"/></noesis:Text.Stroke>
                      </TextBlock>
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </Grid>
        </Border>
          <!-- Close button overlapping border top-right -->
          <Button Command="{Binding events.onDetailCloseClicked}"
                  Width="40" Height="40"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Margin="0,-18,-18,0" BorderThickness="0" Padding="0">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Image Width="40" Height="40" Stretch="Uniform" IsHitTestVisible="True">
                  <Image.Source><Binding Path="closeIconTexture"/></Image.Source>
                </Image>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </Grid>
      </Grid>
    </Grid>
  </Viewbox>
</Grid>
