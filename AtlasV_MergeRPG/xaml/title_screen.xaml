<Grid Background="Black"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

  xmlns:local="clr-namespace:horizon.ui_noesis;assembly=ui_noesis">

  <Grid.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVis" />
  </Grid.Resources>

  <Viewbox Stretch="Uniform">
    <Grid Width="480" Height="800">
      <!-- Background image -->
      <Image Stretch="UniformToFill">
        <Image.Source>
          <Binding Path="backgroundTexture"/>
        </Image.Source>
      </Image>

      <!-- Dark overlay for contrast -->
      <Grid Background="#33000000"/>

      <!-- Title and Play button layout -->
      <Grid>
        <Image Source="/Root;component/sprites/logo.png" Height="250" VerticalAlignment="Top" Margin="20,80,20,0"/>
        <!-- Title area -->

        <!-- Play button with IsPressed trigger for instant feedback -->
        <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,160">
          <Button Width="220" Height="60" Command="{Binding events.onPlayClicked}">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Grid x:Name="ButtonRoot" RenderTransformOrigin="0.5,0.5">
                  <Grid.RenderTransform>
                    <ScaleTransform x:Name="PressScale" ScaleX="1" ScaleY="1"/>
                  </Grid.RenderTransform>
                  <Border x:Name="BackgroundBorder001" Padding="0" Background="#C8000000" CornerRadius="25,25,25,25" Margin="-2,0,-2,-4"/>

                  <Border x:Name="BackgroundBorder" Padding="0" CornerRadius="20,20,20,20" BorderBrush="#FFFFFFFF" BorderThickness="0,2,0,0">
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFD700" Offset="0"/>
                        <GradientStop Color="#FFCC8800" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="PLAY" FontFamily="Bangers" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="48" Foreground="#FF000000"/>
                  </Border>
                </Grid>

                <ControlTemplate.Triggers>
                  <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="PressScale" Property="ScaleX" Value="0.95"/>
                    <Setter TargetName="PressScale" Property="ScaleY" Value="0.95"/>
                    <Setter TargetName="BackgroundBorder" Property="Background" Value="#FFB89020"/>
                  </Trigger>
                </ControlTemplate.Triggers>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Grid>

      <!-- Fade to black overlay -->
      <Grid Background="Black" Opacity="{Binding fadeOpacity}"
            Visibility="{Binding fadeVisible, Converter={StaticResource BoolToVis}}"
            IsHitTestVisible="False"/>
    </Grid>
  </Viewbox>
</Grid>
