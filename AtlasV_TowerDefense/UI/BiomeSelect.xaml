<Component xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:noesis="clr-namespace:NoesisGUIExtensions"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           mc:Ignorable="d">
  <noesis:LayoutScaler ReferenceResolution="1080,1920">
    <Grid>
      <!-- Dark background -->
      <Grid Background="#FF1a1a2e"/>
      <Grid x:Name="ContentContainer" Margin="48,240,48,120">
        <!-- Center content vertically and horizontally -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="800">

          <!-- Title -->
          <TextBlock Text="SELECT BIOME"
                     FontFamily="Anton"
                     FontSize="96"
                     FontWeight="Bold"
                     Foreground="#FFF5C518"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,80"/>

          <!-- Subtitle (debug note) -->
          <TextBlock Text="(Debug — choose a biome for this run)"
                     FontFamily="Roboto"
                     FontSize="36"
                     Foreground="#99FFFFFF"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,60"/>

          <!-- Grass Button -->
          <Button Command="{Binding Path=events.biomeTap}"
                  CommandParameter="grass"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,40">
            <Border CornerRadius="24"
                    BorderThickness="6"
                    BorderBrush="#FF4CAF50"
                    Height="140"
                    HorizontalAlignment="Stretch">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#FF1B3A1B" Offset="0"/>
                  <GradientStop Color="#FF2E5B2E" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="🌿  GRASS"
                         FontFamily="Anton"
                         FontSize="72"
                         Foreground="#FF8BC34A"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
          </Button>

          <!-- Snow Button -->
          <Button Command="{Binding Path=events.biomeTap}"
                  CommandParameter="snow"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,40">
            <Border CornerRadius="24"
                    BorderThickness="6"
                    BorderBrush="#FF81D4FA"
                    Height="140"
                    HorizontalAlignment="Stretch">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#FF1A2A3A" Offset="0"/>
                  <GradientStop Color="#FF2E4A5E" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="SNOW"
                         FontFamily="Anton"
                         FontSize="72"
                         Foreground="#FFB3E5FC"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
          </Button>

          <!-- Volcano Button -->
          <Button Command="{Binding Path=events.biomeTap}"
                  CommandParameter="volcano"
                  Background="Transparent"
                  BorderThickness="0"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,0,40">
            <Border CornerRadius="24"
                    BorderThickness="6"
                    BorderBrush="#FFFF5722"
                    Height="140"
                    HorizontalAlignment="Stretch">
              <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                  <GradientStop Color="#FF3A1A0A" Offset="0"/>
                  <GradientStop Color="#FF5B2E1B" Offset="1"/>
                </LinearGradientBrush>
              </Border.Background>
              <TextBlock Text="VOLCANO"
                         FontFamily="Anton"
                         FontSize="72"
                         Foreground="#FFFF8A65"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
          </Button>

        </StackPanel>
      </Grid>
    </Grid>
  </noesis:LayoutScaler>
</Component>
