<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920"
      Background="Transparent">

    <Page.Resources>
        <SolidColorBrush x:Key="GoldBrush" Color="#f5c518"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#c9a000"/>
        <SolidColorBrush x:Key="CrimsonBrush" Color="#8b0000"/>
        <SolidColorBrush x:Key="CreamBrush" Color="#f5e6c8"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid>
        <!-- ═══════════════════════════════════════════════════════════════
             BOSS LEVEL BANNER — centered dramatic overlay, auto-dismiss
             ═══════════════════════════════════════════════════════════════ -->
        <Grid HorizontalAlignment="Center"
              VerticalAlignment="Center"
              Opacity="{Binding Path=bannerOpacity}"
              Visibility="{Binding showBanner, Converter={StaticResource BoolToVis}}">

            <!-- Dark ominous panel with red tint -->
            <Border Background="#EE0d0d1a"
                    CornerRadius="20"
                    Padding="80,50"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="700"
                    BorderBrush="{StaticResource CrimsonBrush}"
                    BorderThickness="6">

                <Grid>
                    <!-- Inner gold border accent -->
                    <Border BorderBrush="#55f5c518" BorderThickness="3" CornerRadius="14" Margin="-10"/>

                    <!-- Corner Ornaments -->
                    <Ellipse Width="26" Height="26" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-24,-12,0,0"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-19,-7,0,0"/>
                    <Ellipse Width="26" Height="26" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-12,-24,0"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-7,-19,0"/>
                    <Ellipse Width="26" Height="26" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-24,0,0,-12"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-19,0,0,-7"/>
                    <Ellipse Width="26" Height="26" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-24,-12"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-19,-7"/>

                    <!-- Content -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Skull icon -->
                        <Viewbox Width="120" Height="120" HorizontalAlignment="Center" Margin="0,0,0,20">
                            <Path Fill="{StaticResource GoldBrush}"
                                  Data="M12 2C6.48 2 2 6.48 2 12c0 3.69 2.01 6.92 5 8.65V22h2v-1h2v1h2v-1h2v1h2v-1.35c2.99-1.73 5-4.96 5-8.65 0-5.52-4.48-10-10-10zm-3 14c-.83 0-1.5-.67-1.5-1.5S8.17 13 9 13s1.5.67 1.5 1.5S9.83 16 9 16zm6 0c-.83 0-1.5-.67-1.5-1.5S14.17 13 15 13s1.5.67 1.5 1.5S15.83 16 15 16z"/>
                        </Viewbox>

                        <!-- "BOSS LEVEL" title with fiery gold text + outline -->
                        <Grid HorizontalAlignment="Center">
                            <TextBlock Text="BOSS LEVEL" FontFamily="Anton" FontSize="120" FontWeight="Bold"
                                       Foreground="Black" Margin="-5,0,0,0"/>
                            <TextBlock Text="BOSS LEVEL" FontFamily="Anton" FontSize="120" FontWeight="Bold"
                                       Foreground="Black" Margin="5,0,0,0"/>
                            <TextBlock Text="BOSS LEVEL" FontFamily="Anton" FontSize="120" FontWeight="Bold"
                                       Foreground="Black" Margin="0,-5,0,0"/>
                            <TextBlock Text="BOSS LEVEL" FontFamily="Anton" FontSize="120" FontWeight="Bold"
                                       Foreground="Black" Margin="0,5,0,0"/>
                            <TextBlock Text="BOSS LEVEL" FontFamily="Anton" FontSize="120" FontWeight="Bold"
                                       Foreground="{StaticResource GoldBrush}"/>
                        </Grid>

                        <!-- Subtitle -->
                        <Grid HorizontalAlignment="Center" Margin="0,10,0,0">
                            <TextBlock Text="Prepare yourself..." FontFamily="Almendra" FontSize="56"
                                       Foreground="Black" Margin="-3,0,0,0"/>
                            <TextBlock Text="Prepare yourself..." FontFamily="Almendra" FontSize="56"
                                       Foreground="Black" Margin="3,0,0,0"/>
                            <TextBlock Text="Prepare yourself..." FontFamily="Almendra" FontSize="56"
                                       Foreground="Black" Margin="0,-3,0,0"/>
                            <TextBlock Text="Prepare yourself..." FontFamily="Almendra" FontSize="56"
                                       Foreground="Black" Margin="0,3,0,0"/>
                            <TextBlock Text="Prepare yourself..." FontFamily="Almendra" FontSize="56"
                                       Foreground="#e74c3c"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════════
             ACTIVE MODIFIER BADGE — single large prominent badge
             Positioned below the top HUD bar (~300px from top)
             ═══════════════════════════════════════════════════════════════ -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,300,0,0"
                Visibility="{Binding showModifiers, Converter={StaticResource BoolToVis}}">

            <Border Background="#EE0d0d1a"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="5"
                    CornerRadius="20"
                    Padding="48,24,48,24"
                    MinWidth="400">

                <Grid HorizontalAlignment="Center">
                    <!-- Inner accent border -->
                    <Border BorderBrush="#44f5c518" BorderThickness="2" CornerRadius="14" Margin="-12,-6"/>

                    <!-- Modifier text with outline for readability -->
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="400">
                        <TextBlock Text="{Binding modifierText}" FontFamily="Anton" FontSize="72" FontWeight="Bold"
                                   Foreground="Black" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="-3,0,0,0"/>
                        <TextBlock Text="{Binding modifierText}" FontFamily="Anton" FontSize="72" FontWeight="Bold"
                                   Foreground="Black" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="3,0,0,0"/>
                        <TextBlock Text="{Binding modifierText}" FontFamily="Anton" FontSize="72" FontWeight="Bold"
                                   Foreground="Black" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,-3,0,0"/>
                        <TextBlock Text="{Binding modifierText}" FontFamily="Anton" FontSize="72" FontWeight="Bold"
                                   Foreground="Black" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        <TextBlock Text="{Binding modifierText}" FontFamily="Anton" FontSize="72" FontWeight="Bold"
                                   Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
