<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d"
      d:DesignWidth="1080" d:DesignHeight="1920">

    <Page.Resources>
        <!-- Colors matching TowerShop/GameOverScreen medieval fantasy style -->
        <SolidColorBrush x:Key="GoldBrush" Color="#f5c518"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#c9a000"/>
        <SolidColorBrush x:Key="WoodBrush" Color="#2a1a0e"/>
        <SolidColorBrush x:Key="RedBrush" Color="#e74c3c"/>
        <SolidColorBrush x:Key="CreamBrush" Color="#f5e6c8"/>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
    </Page.Resources>
    <Page.Visibility>
        <Binding Path="visible">
            <Binding.Converter>
                <BooleanToVisibilityConverter/>
            </Binding.Converter>
        </Binding>
    </Page.Visibility>

    <Grid>
    <!-- Countdown overlay - centered on screen, shown only before wave 1 -->
    <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
          IsHitTestVisible="False"
          Visibility="{Binding showCountdown, Converter={StaticResource BoolToVisConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Label -->
        <Grid Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
            <TextBlock Text="WAVE INCOMING!" FontFamily="Anton" FontSize="90" FontWeight="Bold" Foreground="{StaticResource CreamBrush}"/>
        </Grid>
        <!-- Big countdown number -->
        <Grid Grid.Row="1" HorizontalAlignment="Center">
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="-6,0,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="6,0,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="0,-6,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="Black" Margin="0,6,0,0"/>
            <TextBlock Text="{Binding countdown, StringFormat=F0}" FontFamily="Anton" FontSize="400" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
        </Grid>
    </Grid>

    <!-- Top HUD Bar - Lives (left), Wave (center), and Gold (right) -->
    <Grid VerticalAlignment="Top" Height="280" IsHitTestVisible="False">
        <!-- Dark wood gradient background matching TowerShop bottom bar -->
        <Border CornerRadius="0,0,40,40">
            <Border.Background>
                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                    <GradientStop Color="#F02a1a0e" Offset="0"/>
                    <GradientStop Color="#FF0a0500" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <!-- Gold top border line -->
            <Border BorderThickness="0,6,0,0" BorderBrush="#553B14"/>
        </Border>
        
        <!-- Content: Three sections - left, center, and right aligned -->
        <Grid Margin="80,30,80,30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SECTION: Lives Counter Panel -->
            <Border Grid.Column="0" 
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Background="#CC1a1a2e"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="6"
                    CornerRadius="20"
                    Padding="30,15,40,15">
                <Grid>
                    <!-- Corner Ornaments - Top Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-20,-8,0,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-16,-4,0,0"/>
                    <!-- Corner Ornaments - Top Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-8,-20,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-4,-16,0"/>
                    <!-- Corner Ornaments - Bottom Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-20,0,0,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-16,0,0,-4"/>
                    <!-- Corner Ornaments - Bottom Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-20,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-16,-4"/>

                    <!-- Lives Content -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Heart icon with gold outline stroke -->
                        <Viewbox Width="120" Height="120" Margin="0,0,25,0">
                            <Grid>
                                <!-- Gold outline stroke (slightly larger) -->
                                <Path Fill="{StaticResource GoldBrush}"
                                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <ScaleTransform ScaleX="1.15" ScaleY="1.15"/>
                                    </Path.RenderTransform>
                                </Path>
                                <!-- Red heart fill -->
                                <Path Fill="{StaticResource RedBrush}"
                                      Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
                            </Grid>
                        </Viewbox>
                        <!-- Lives value with outlined text -->
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Path=lives, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="{StaticResource CreamBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CENTER SECTION: Wave with outlined text -->
            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0">
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding Path=waveText}" 
                           FontSize="80" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
            </Grid>

            <!-- RIGHT SECTION: Gold Counter Panel -->
            <Border Grid.Column="2" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="#CC1a1a2e"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="6"
                    CornerRadius="20"
                    Padding="30,15,40,15">
                <Grid>
                    <!-- Corner Ornaments - Top Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-20,-8,0,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="-16,-4,0,0"/>
                    <!-- Corner Ornaments - Top Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-8,-20,0"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-4,-16,0"/>
                    <!-- Corner Ornaments - Bottom Left -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-20,0,0,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom"
                             Margin="-16,0,0,-4"/>
                    <!-- Corner Ornaments - Bottom Right -->
                    <Ellipse Width="22" Height="22" 
                             Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-20,-8"/>
                    <Ellipse Width="14" Height="14" 
                             Fill="{StaticResource GoldDarkBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom"
                             Margin="0,0,-16,-4"/>

                    <!-- Gold Content -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Gold icon from image -->
                        <Image Source="/Root;component/Textures/gold_icon.png" 
                               Width="120" 
                               Height="120" 
                               Margin="0,0,25,0"
                               VerticalAlignment="Center"/>
                        <!-- Gold value with outlined text -->
                        <Grid VerticalAlignment="Center">
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding Path=gold, StringFormat=F0}" 
                                       FontSize="120" FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <!-- Finish Level (Debug) Button - top-left, below the HUD bar, visible only during Wave phase -->
    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="80,300,0,0"
            Visibility="{Binding showFinishLevel, Converter={StaticResource BoolToVisConverter}}">
        <Button Command="{Binding events.finishLevelTap}" CommandParameter="finish"
                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
            <Border Background="#CC1a1a2e"
                    BorderBrush="#44CC44"
                    BorderThickness="4"
                    CornerRadius="14"
                    Padding="24,12,24,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Checkmark icon -->
                    <Viewbox Width="40" Height="40" Margin="0,0,10,0">
                        <Path Fill="#44CC44"
                              Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                    </Viewbox>
                    <!-- Text with outline -->
                    <Grid>
                        <TextBlock Text="FINISH" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="-2,0,0,0"/>
                        <TextBlock Text="FINISH" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="2,0,0,0"/>
                        <TextBlock Text="FINISH" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="0,-2,0,0"/>
                        <TextBlock Text="FINISH" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="0,2,0,0"/>
                        <TextBlock Text="FINISH" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="#44CC44"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Button>
    </Border>

    <!-- Kill Wave (Debug) Button - below Finish button, visible only during Wave phase -->
    <Border HorizontalAlignment="Left" VerticalAlignment="Top"
            Margin="80,400,0,0"
            Visibility="{Binding showNextWave, Converter={StaticResource BoolToVisConverter}}">
        <Button Command="{Binding events.nextWaveTap}" CommandParameter="nextwave"
                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
            <Border Background="#CC1a1a2e"
                    BorderBrush="#FF8844"
                    BorderThickness="4"
                    CornerRadius="14"
                    Padding="24,12,24,12">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <!-- Skull icon -->
                    <Viewbox Width="40" Height="40" Margin="0,0,10,0">
                        <Path Fill="#FF8844"
                              Data="M12 2C6.48 2 2 6.48 2 12c0 3.69 2.01 6.92 5 8.65V22h2v-1h2v1h2v-1h2v1h2v-1.35c2.99-1.73 5-4.96 5-8.65 0-5.52-4.48-10-10-10zm-3 14c-.83 0-1.5-.67-1.5-1.5S8.17 13 9 13s1.5.67 1.5 1.5S9.83 16 9 16zm6 0c-.83 0-1.5-.67-1.5-1.5S14.17 13 15 13s1.5.67 1.5 1.5S15.83 16 15 16z"/>
                    </Viewbox>
                    <!-- Text with outline -->
                    <Grid>
                        <TextBlock Text="KILL" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="-2,0,0,0"/>
                        <TextBlock Text="KILL" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="2,0,0,0"/>
                        <TextBlock Text="KILL" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="0,-2,0,0"/>
                        <TextBlock Text="KILL" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="Black" Margin="0,2,0,0"/>
                        <TextBlock Text="KILL" FontFamily="Anton" FontSize="44" FontWeight="Bold"
                                   Foreground="#FF8844"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Button>
    </Border>

    <!-- Abandon Level Button - top-right, below the HUD bar -->
    <Border HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0,300,80,0"
            Visibility="{Binding showAbandon, Converter={StaticResource BoolToVisConverter}}">
        <Button Command="{Binding events.abandonLevelTap}" CommandParameter="abandon"
                Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand">
            <Border Background="#CC1a1a2e"
                    BorderBrush="{StaticResource GoldBrush}"
                    BorderThickness="5"
                    CornerRadius="18"
                    Padding="32,16,32,16">
                <Grid>
                    <!-- Corner dots -->
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-14,-6,0,0"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-14,0"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-14,0,0,-6"/>
                    <Ellipse Width="16" Height="16" Fill="{StaticResource GoldBrush}"
                             HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-14,-6"/>
                    <!-- Button text -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <!-- X icon -->
                        <Viewbox Width="50" Height="50" Margin="0,0,14,0">
                            <Path Fill="{StaticResource RedBrush}"
                                  Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"/>
                        </Viewbox>
                        <!-- Text with outline -->
                        <Grid>
                            <TextBlock Text="ABANDON" FontFamily="Anton" FontSize="56" FontWeight="Bold"
                                       Foreground="Black" Margin="-3,0,0,0"/>
                            <TextBlock Text="ABANDON" FontFamily="Anton" FontSize="56" FontWeight="Bold"
                                       Foreground="Black" Margin="3,0,0,0"/>
                            <TextBlock Text="ABANDON" FontFamily="Anton" FontSize="56" FontWeight="Bold"
                                       Foreground="Black" Margin="0,-3,0,0"/>
                            <TextBlock Text="ABANDON" FontFamily="Anton" FontSize="56" FontWeight="Bold"
                                       Foreground="Black" Margin="0,3,0,0"/>
                            <TextBlock Text="ABANDON" FontFamily="Anton" FontSize="56" FontWeight="Bold"
                                       Foreground="{StaticResource CreamBrush}"/>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>
        </Button>
    </Border>
    <!-- Confirmation Popup Overlay -->
    <Grid Visibility="{Binding showConfirmPopup, Converter={StaticResource BoolToVisConverter}}">
        <!-- Semi-transparent dimmer background -->
        <Border Background="#AA000000"/>

        <!-- Popup panel centered -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#F02a1a0e"
                BorderBrush="{StaticResource GoldBrush}"
                BorderThickness="6"
                CornerRadius="28"
                Padding="60,40,60,40"
                MinWidth="600">
            <Grid>
                <!-- Corner Ornaments -->
                <Ellipse Width="24" Height="24" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-24,-10,0,0"/>
                <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-20,-6,0,0"/>
                <Ellipse Width="24" Height="24" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-24,0"/>
                <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-6,-20,0"/>
                <Ellipse Width="24" Height="24" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-24,0,0,-10"/>
                <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-20,0,0,-6"/>
                <Ellipse Width="24" Height="24" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-24,-10"/>
                <Ellipse Width="16" Height="16" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-20,-6"/>

                <!-- Content -->
                <StackPanel HorizontalAlignment="Center">
                    <!-- Title text with outline -->
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,40">
                        <TextBlock Text="Are you sure?" FontFamily="Anton" FontSize="80" FontWeight="Bold"
                                   Foreground="Black" Margin="-4,0,0,0"/>
                        <TextBlock Text="Are you sure?" FontFamily="Anton" FontSize="80" FontWeight="Bold"
                                   Foreground="Black" Margin="4,0,0,0"/>
                        <TextBlock Text="Are you sure?" FontFamily="Anton" FontSize="80" FontWeight="Bold"
                                   Foreground="Black" Margin="0,-4,0,0"/>
                        <TextBlock Text="Are you sure?" FontFamily="Anton" FontSize="80" FontWeight="Bold"
                                   Foreground="Black" Margin="0,4,0,0"/>
                        <TextBlock Text="Are you sure?" FontFamily="Anton" FontSize="80" FontWeight="Bold"
                                   Foreground="{StaticResource CreamBrush}"/>
                    </Grid>

                    <!-- Buttons row -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <!-- YES button -->
                        <Button Command="{Binding events.confirmYesTap}" CommandParameter="yes"
                                Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,40,0">
                            <Border Background="#CC2e7d32"
                                    BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="5"
                                    CornerRadius="18"
                                    Padding="50,20,50,20"
                                    MinWidth="220">
                                <Grid HorizontalAlignment="Center">
                                    <TextBlock Text="YES" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="-3,0,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="YES" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="3,0,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="YES" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="0,-3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="YES" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="YES" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="{StaticResource CreamBrush}" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Button>

                        <!-- NO button -->
                        <Button Command="{Binding events.confirmNoTap}" CommandParameter="no"
                                Background="Transparent" BorderThickness="0" Padding="0">
                            <Border Background="#CCc62828"
                                    BorderBrush="{StaticResource GoldBrush}"
                                    BorderThickness="5"
                                    CornerRadius="18"
                                    Padding="50,20,50,20"
                                    MinWidth="220">
                                <Grid HorizontalAlignment="Center">
                                    <TextBlock Text="NO" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="-3,0,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NO" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="3,0,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NO" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="0,-3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NO" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="Black" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NO" FontFamily="Anton" FontSize="64" FontWeight="Bold"
                                               Foreground="{StaticResource CreamBrush}" HorizontalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

    </Grid>
</Page>
