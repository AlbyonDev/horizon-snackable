<Component xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:noesis="clr-namespace:NoesisGUIExtensions"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           mc:Ignorable="d"
           d:DesignWidth="1080" d:DesignHeight="1920">

  <Component.Resources>
    <!-- Card positioning style for ItemsControl on Canvas -->
    <Style x:Key="CardPositionStyle" TargetType="ContentPresenter">
      <Setter Property="Canvas.Left" Value="{Binding Path=posX}"/>
      <Setter Property="Canvas.Top" Value="{Binding Path=posY}"/>
    </Style>
  </Component.Resources>

  <noesis:LayoutScaler ReferenceResolution="1080,1920">
    <Grid>
      <!-- Full-screen dark overlay -->
      <Grid Background="#CC000000"/>

      <!-- Main content (visibility bound) -->
      <Grid x:Name="ContentContainer">
        <Grid.Visibility>
          <Binding Path="visible">
            <Binding.Converter>
              <BooleanToVisibilityConverter/>
            </Binding.Converter>
          </Binding>
        </Grid.Visibility>

        <!-- Title text in styled box -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,200,0,0"
                Background="#CC1a1a2e"
                BorderBrush="#f5c518"
                BorderThickness="6"
                CornerRadius="20"
                Padding="24,10,30,10">
          <Border.Visibility>
            <Binding Path="titleVisible">
              <Binding.Converter>
                <BooleanToVisibilityConverter/>
              </Binding.Converter>
            </Binding>
          </Border.Visibility>
          <Grid>
            <!-- Corner Ornaments - Top Left -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-20,-8,0,0"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-16,-4,0,0"/>
            <!-- Corner Ornaments - Top Right -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-20,0"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-16,0"/>
            <!-- Corner Ornaments - Bottom Left -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-20,0,0,-8"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-16,0,0,-4"/>
            <!-- Corner Ornaments - Bottom Right -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-20,-8"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-16,-4"/>

            <!-- Title text with outline -->
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="{Binding Path=titleText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=titleText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=titleText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=titleText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=titleText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="#f5c518"
                         HorizontalAlignment="Center"/>
            </Grid>
          </Grid>
        </Border>

        <!-- Cards area (Canvas for absolute positioning) -->
        <ItemsControl ItemsSource="{Binding Path=cards}"
                      ItemContainerStyle="{StaticResource CardPositionStyle}"
                      Margin="0,0,0,0">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <Canvas/>
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Command="{Binding DataContext.events.cardTap, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                      CommandParameter="{Binding Path=cardIndex}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      Width="208" Height="304"
                      RenderTransformOrigin="0.5,0.5">
                <Button.RenderTransform>
                  <ScaleTransform ScaleX="{Binding Path=cardScaleX}" ScaleY="{Binding Path=cardScaleY}"/>
                </Button.RenderTransform>
                <Grid Width="208" Height="304">
                  <!-- Card Back (shown when face down) -->
                  <Border CornerRadius="20"
                          BorderBrush="#f5c518"
                          BorderThickness="6"
                          Width="208" Height="304">
                    <Border.Visibility>
                      <Binding Path="faceDown">
                        <Binding.Converter>
                          <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                      </Binding>
                    </Border.Visibility>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#1a0a2e" Offset="0"/>
                        <GradientStop Color="#2a1a3e" Offset="0.5"/>
                        <GradientStop Color="#1a0a2e" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid>
                      <!-- Decorative back pattern -->
                      <Border CornerRadius="12" BorderBrush="#b8860b" BorderThickness="3" Margin="20">
                        <Grid>
                          <TextBlock Text="?" FontSize="120"
                                     Foreground="#f5c518"
                                     FontFamily="Almendra"
                                     FontWeight="Bold"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                        </Grid>
                      </Border>
                      <!-- Corner ornaments -->
                      <Grid Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="8">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="8">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                      </Grid>
                    </Grid>
                  </Border>

                  <!-- Card Front (shown when face up) -->
                  <Border CornerRadius="20"
                          BorderBrush="#f5c518"
                          BorderThickness="6"
                          Width="208" Height="304">
                    <Border.Visibility>
                      <Binding Path="faceUp">
                        <Binding.Converter>
                          <BooleanToVisibilityConverter/>
                        </Binding.Converter>
                      </Binding>
                    </Border.Visibility>
                    <Border.Background>
                      <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#2a1a0a" Offset="0"/>
                        <GradientStop Color="#1a1a2e" Offset="0.5"/>
                        <GradientStop Color="#2a1a0a" Offset="1"/>
                      </LinearGradientBrush>
                    </Border.Background>
                    <Grid Margin="16">
                      <!-- Corner ornaments -->
                      <Grid Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Top">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                        <Ellipse Fill="#b8860b" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                        <Ellipse Fill="#b8860b" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                        <Ellipse Fill="#b8860b" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                      <Grid Width="20" Height="20" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                        <Ellipse Fill="#f5c518" Width="20" Height="20"/>
                        <Ellipse Fill="#b8860b" Width="12" Height="12" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>

                      <!-- Card content -->
                      <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Border Width="100" Height="100"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,16"
                                CornerRadius="8">
                          <Border.Background>
                            <ImageBrush ImageSource="{Binding Path=iconImage}" Stretch="Uniform"/>
                          </Border.Background>
                        </Border>
                        <TextBlock Text="{Binding Path=label}"
                                   FontSize="44" FontWeight="Bold"
                                   Foreground="#f5c518"
                                   FontFamily="Almendra"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                      </StackPanel>
                    </Grid>
                  </Border>
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Feedback text in styled box -->
        <Border VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,440"
                Background="#CC1a1a2e"
                BorderBrush="#f5c518"
                BorderThickness="6"
                CornerRadius="20"
                Padding="24,10,30,10">
          <Border.Visibility>
            <Binding Path="feedbackVisible">
              <Binding.Converter>
                <BooleanToVisibilityConverter/>
              </Binding.Converter>
            </Binding>
          </Border.Visibility>
          <Grid>
            <!-- Corner Ornaments - Top Left -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-20,-8,0,0"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-16,-4,0,0"/>
            <!-- Corner Ornaments - Top Right -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-8,-20,0"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-4,-16,0"/>
            <!-- Corner Ornaments - Bottom Left -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-20,0,0,-8"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-16,0,0,-4"/>
            <!-- Corner Ornaments - Bottom Right -->
            <Ellipse Width="22" Height="22" Fill="#f5c518"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-20,-8"/>
            <Ellipse Width="14" Height="14" Fill="#c9a000"
                     HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-16,-4"/>

            <!-- Feedback text with outline -->
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
              <TextBlock Text="{Binding Path=feedbackText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="-4,0,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=feedbackText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="4,0,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=feedbackText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="0,-4,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=feedbackText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="Black" Margin="0,4,0,0"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="{Binding Path=feedbackText}" FontFamily="Anton"
                         FontSize="96" FontWeight="Bold" Foreground="#f5c518"
                         HorizontalAlignment="Center"/>
            </Grid>
          </Grid>
        </Border>

      </Grid>
    </Grid>
  </noesis:LayoutScaler>
</Component>
