<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d">

    <Page.Resources>
        <!-- Colors matching medieval fantasy style -->
        <SolidColorBrush x:Key="GoldBrush" Color="#FFf5c518"/>
        <SolidColorBrush x:Key="GoldDarkBrush" Color="#FFc9a000"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#FFF5E6C8"/>
        <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

        <!-- Horizontal wrap panel for level buttons -->
        <ItemsPanelTemplate x:Key="LevelGridPanel">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
        </ItemsPanelTemplate>

        <!-- Level Button Item Template -->
        <DataTemplate x:Key="LevelButtonTemplate">
            <Grid Width="280" Height="280" Margin="24,24,24,24">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonUp">
                        <b:InvokeCommandAction Command="{Binding DataContext.events.levelTap, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding levelIndex}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <!-- Shadow -->
                <Border Margin="8,8,0,0" CornerRadius="28" Background="#FF000000"/>

                <!-- Main button border -->
                <Border CornerRadius="28" BorderThickness="8" BorderBrush="{StaticResource GoldBrush}">
                    <Border.Background>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF1a0a00" Offset="0"/>
                            <GradientStop Color="#FF3D2407" Offset="1"/>
                        </RadialGradientBrush>
                    </Border.Background>

                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <!-- Level number with text shadow -->
                        <TextBlock Text="{Binding levelNumber}" FontSize="120" FontWeight="Bold"
                                   FontFamily="Anton" Foreground="Black" Margin="-4,0,0,0"/>
                        <TextBlock Text="{Binding levelNumber}" FontSize="120" FontWeight="Bold"
                                   FontFamily="Anton" Foreground="Black" Margin="4,0,0,0"/>
                        <TextBlock Text="{Binding levelNumber}" FontSize="120" FontWeight="Bold"
                                   FontFamily="Anton" Foreground="Black" Margin="0,-4,0,0"/>
                        <TextBlock Text="{Binding levelNumber}" FontSize="120" FontWeight="Bold"
                                   FontFamily="Anton" Foreground="Black" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding levelNumber}" FontSize="120" FontWeight="Bold"
                                   FontFamily="Anton" Foreground="{StaticResource TextLightBrush}"/>
                    </Grid>
                </Border>

                <!-- Corner ornaments -->
                <Ellipse Width="20" Height="20" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,12,0,0"/>
                <Ellipse Width="12" Height="12" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,16,0,0"/>
                <Ellipse Width="20" Height="20" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"/>
                <Ellipse Width="12" Height="12" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,16,16,0"/>
                <Ellipse Width="20" Height="20" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="12,0,0,12"/>
                <Ellipse Width="12" Height="12" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="16,0,0,16"/>
                <Ellipse Width="20" Height="20" Fill="{StaticResource GoldBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,12,12"/>
                <Ellipse Width="12" Height="12" Fill="{StaticResource GoldDarkBrush}"
                         HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <!-- Main Container -->
    <Grid>
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>
        <Grid.Background>
            <RadialGradientBrush>
                <GradientStop Color="#FF000000" Offset="0"/>
                <GradientStop Color="#FF1A1A2E" Offset="1"/>
            </RadialGradientBrush>
        </Grid.Background>

        <!-- Layout -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.12*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0.06*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.12*"/>
            </Grid.RowDefinitions>

            <!-- Title: SELECT LEVEL -->
            <Grid Grid.Row="1" HorizontalAlignment="Center">
                <TextBlock Text="SELECT LEVEL" FontSize="100" FontWeight="Bold"
                           FontFamily="Anton" Foreground="Black" Margin="-4,0,0,0"/>
                <TextBlock Text="SELECT LEVEL" FontSize="100" FontWeight="Bold"
                           FontFamily="Anton" Foreground="Black" Margin="4,0,0,0"/>
                <TextBlock Text="SELECT LEVEL" FontSize="100" FontWeight="Bold"
                           FontFamily="Anton" Foreground="Black" Margin="0,-4,0,0"/>
                <TextBlock Text="SELECT LEVEL" FontSize="100" FontWeight="Bold"
                           FontFamily="Anton" Foreground="Black" Margin="0,4,0,0"/>
                <TextBlock Text="SELECT LEVEL" FontSize="100" FontWeight="Bold"
                           FontFamily="Anton" Foreground="{StaticResource GoldBrush}"/>
            </Grid>

            <!-- Level Buttons Grid -->
            <ItemsControl Grid.Row="3"
                          ItemsSource="{Binding items}"
                          ItemsPanel="{StaticResource LevelGridPanel}"
                          ItemTemplate="{StaticResource LevelButtonTemplate}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Page>
