<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d">

    <Page.Resources>
        <!-- Fantasy adventure map colors -->
        <SolidColorBrush x:Key="GoldBrush" Color="#FFf5c518"/>
        <SolidColorBrush x:Key="TextLightBrush" Color="#FFF5E6C8"/>
        <SolidColorBrush x:Key="ParchmentBrush" Color="#FFF5E6C8"/>
        <SolidColorBrush x:Key="DarkStoneBrush" Color="#FF2A1A0A"/>

        <!-- Canvas panel for absolute positioning -->
        <ItemsPanelTemplate x:Key="CanvasPanel">
            <Canvas/>
        </ItemsPanelTemplate>

        <!-- Horizontal panel for tiled path segments -->
        <ItemsPanelTemplate x:Key="HorizontalPanel">
            <StackPanel Orientation="Horizontal"/>
        </ItemsPanelTemplate>

        <!-- Node container style: positions each node on the canvas -->
        <Style x:Key="NodeContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding posX}"/>
            <Setter Property="Canvas.Top" Value="{Binding posY}"/>
        </Style>

        <!-- Connector container style: positions each connector on the canvas -->
        <Style x:Key="ConnectorContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Canvas.Left" Value="{Binding posX}"/>
            <Setter Property="Canvas.Top" Value="{Binding posY}"/>
        </Style>

        <!-- Individual segment tile template -->
        <DataTemplate x:Key="SegmentTileTemplate">
            <Image Source="sprites/overworld_path_segment.png" Stretch="Fill"
                   Width="{Binding segmentWidth}" Height="{Binding segmentHeight}"
                   VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- Relic icon template -->
        <DataTemplate x:Key="RelicIconTemplate">
            <Border Width="250" Height="250" CornerRadius="8" Margin="0,6"
                    BorderBrush="{StaticResource GoldBrush}" BorderThickness="2"
                    Background="#88000000">
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonUp">
                        <b:InvokeCommandAction Command="{Binding DataContext.events.relicIconTap, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding relicId}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>
                <Border CornerRadius="6" Margin="4">
                    <Border.Background>
                        <ImageBrush ImageSource="{Binding icon}" Stretch="Uniform"/>
                    </Border.Background>
                </Border>
            </Border>
        </DataTemplate>

        <!-- Vertical panel for relic icons column -->
        <ItemsPanelTemplate x:Key="VerticalRelicPanel">
            <StackPanel Orientation="Vertical"/>
        </ItemsPanelTemplate>

        <!-- Path connector template using repeating tiles -->
        <DataTemplate x:Key="ConnectorTemplate">
            <Grid Width="{Binding connectorWidth}" Height="{Binding connectorThickness}" RenderTransformOrigin="0.5,0.5"
                  ClipToBounds="True">
                <Grid.RenderTransform>
                    <RotateTransform Angle="{Binding angle}"/>
                </Grid.RenderTransform>

                <!-- Repeat the path segment pattern using ItemsControl with horizontal layout -->
                <ItemsControl ItemsSource="{Binding segments}"
                              ItemsPanel="{StaticResource HorizontalPanel}"
                              ItemTemplate="{StaticResource SegmentTileTemplate}"
                              VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Level Node template with state-driven sprites -->
        <DataTemplate x:Key="LevelNodeTemplate">
            <Grid Width="{Binding nodeSize}" Height="{Binding nodeSize}" ClipToBounds="False">
                <Grid Width="{Binding nodeSize}" Height="{Binding nodeSize}">
                <!-- Tap handler (command still fires; logic in TS blocks locked taps) -->
                <b:Interaction.Triggers>
                    <b:EventTrigger EventName="MouseLeftButtonUp">
                        <b:InvokeCommandAction Command="{Binding DataContext.events.levelTap, RelativeSource={RelativeSource AncestorType=Page}}"
                                               CommandParameter="{Binding levelIndex}"/>
                    </b:EventTrigger>
                </b:Interaction.Triggers>

                <!-- ═══ COMBAT NODE SPRITES (nodeType=combat) ═══ -->

                <!-- COMBAT BEATEN state sprite -->
                <Image Source="sprites/overworld_node_combat.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="combat"/>
                                        <Condition Binding="{Binding nodeState}" Value="beaten"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- COMBAT OPEN state sprite -->
                <Image Source="sprites/overworld_node_combat_open.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="combat"/>
                                        <Condition Binding="{Binding nodeState}" Value="open"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- COMBAT LOCKED state sprite -->
                <Image Source="sprites/overworld_node_combat_locked.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="combat"/>
                                        <Condition Binding="{Binding nodeState}" Value="locked"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- ═══ BOSS NODE SPRITES (nodeType=boss) ═══ -->

                <!-- BOSS BEATEN state sprite -->
                <Image Source="sprites/overworld_node_boss.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="boss"/>
                                        <Condition Binding="{Binding nodeState}" Value="beaten"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- BOSS OPEN state sprite -->
                <Image Source="sprites/overworld_node_boss_open.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="boss"/>
                                        <Condition Binding="{Binding nodeState}" Value="open"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- BOSS LOCKED state sprite -->
                <Image Source="sprites/overworld_node_boss_locked.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="boss"/>
                                        <Condition Binding="{Binding nodeState}" Value="locked"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- ═══ MINIGAME NODE SPRITES (nodeType=minigame) ═══ -->

                <!-- MINIGAME BEATEN state sprite -->
                <Image Source="sprites/overworld_node_minigame.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="minigame"/>
                                        <Condition Binding="{Binding nodeState}" Value="beaten"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- MINIGAME OPEN state sprite -->
                <Image Source="sprites/overworld_node_minigame_open.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="minigame"/>
                                        <Condition Binding="{Binding nodeState}" Value="open"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- MINIGAME LOCKED state sprite -->
                <Image Source="sprites/overworld_node_minigame_locked.png" Stretch="Uniform">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding nodeType}" Value="minigame"/>
                                        <Condition Binding="{Binding nodeState}" Value="locked"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- Level number with text outline effect -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{Binding numberMargin}">
                    <TextBlock Text="{Binding levelNumber}" FontSize="{Binding fontSize}" FontWeight="Bold"
                               FontFamily="Anton" Foreground="#FF1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="-2,0,0,0"/>
                    <TextBlock Text="{Binding levelNumber}" FontSize="{Binding fontSize}" FontWeight="Bold"
                               FontFamily="Anton" Foreground="#FF1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="2,0,0,0"/>
                    <TextBlock Text="{Binding levelNumber}" FontSize="{Binding fontSize}" FontWeight="Bold"
                               FontFamily="Anton" Foreground="#FF1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                    <TextBlock Text="{Binding levelNumber}" FontSize="{Binding fontSize}" FontWeight="Bold"
                               FontFamily="Anton" Foreground="#FF1A1A1A"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding levelNumber}" FontSize="{Binding fontSize}" FontWeight="Bold"
                               FontFamily="Anton" Foreground="{StaticResource TextLightBrush}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                </Grid>

                <!-- Boss modifier label (shown to the right of the node for boss type only) -->
                <Border HorizontalAlignment="Left" VerticalAlignment="Center"
                        CornerRadius="12" Padding="28,16" BorderThickness="4"
                        Width="420"
                        BorderBrush="{StaticResource GoldBrush}" Background="#F00d0d1a">
                    <Border.RenderTransform>
                        <TranslateTransform X="{Binding modifierOffsetX}"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding nodeType}" Value="boss">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Title: BOSS MODIFIER -->
                        <Grid HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="BOSS MODIFIER" FontSize="38" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" Margin="-2,0,0,0"/>
                            <TextBlock Text="BOSS MODIFIER" FontSize="38" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" Margin="2,0,0,0"/>
                            <TextBlock Text="BOSS MODIFIER" FontSize="38" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            <TextBlock Text="BOSS MODIFIER" FontSize="38" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="BOSS MODIFIER" FontSize="38" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center"/>
                        </Grid>
                        <!-- Modifier explanation text with outline -->
                        <Grid HorizontalAlignment="Center" MaxWidth="360">
                            <TextBlock Text="{Binding modifierLabel}" FontSize="50" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="-2,0,0,0"/>
                            <TextBlock Text="{Binding modifierLabel}" FontSize="50" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="2,0,0,0"/>
                            <TextBlock Text="{Binding modifierLabel}" FontSize="50" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,-2,0,0"/>
                            <TextBlock Text="{Binding modifierLabel}" FontSize="50" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="#FF1A1A0A"
                                       HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding modifierLabel}" FontSize="50" FontWeight="Bold"
                                       FontFamily="Anton" Foreground="{StaticResource GoldBrush}"
                                       HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <!-- Main Container -->
    <Grid>
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <!-- Full-screen fantasy landscape background -->
        <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border.Background>
                <ImageBrush ImageSource="{Binding backgroundImage}" Stretch="UniformToFill"/>
            </Border.Background>
        </Border>

        <!-- Semi-transparent dark overlay for readability -->
        <Border Background="#22000000"/>

        <!-- Layout -->
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="0.10*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0.03*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="0.06*"/>
            </Grid.RowDefinitions>

            <!-- Title: SELECT LEVEL with ornate text -->
            <Grid Grid.Row="1" HorizontalAlignment="Center">
                <!-- Title outline shadow -->
                <TextBlock Text="SELECT LEVEL" FontSize="96" FontWeight="Bold"
                           FontFamily="Almendra" Foreground="#FF2A1A0A" Margin="-3,0,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="SELECT LEVEL" FontSize="96" FontWeight="Bold"
                           FontFamily="Almendra" Foreground="#FF2A1A0A" Margin="3,0,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="SELECT LEVEL" FontSize="96" FontWeight="Bold"
                           FontFamily="Almendra" Foreground="#FF2A1A0A" Margin="0,-3,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="SELECT LEVEL" FontSize="96" FontWeight="Bold"
                           FontFamily="Almendra" Foreground="#FF2A1A0A" Margin="0,3,0,0"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="SELECT LEVEL" FontSize="96" FontWeight="Bold"
                           FontFamily="Almendra" HorizontalAlignment="Center">
                    <TextBlock.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#FFFFD700" Offset="0"/>
                            <GradientStop Color="#FFE8A800" Offset="0.5"/>
                            <GradientStop Color="#FFCC8800" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.Foreground>
                </TextBlock>
            </Grid>

            <!-- Winding path scroll area -->
            <ScrollViewer Grid.Row="3"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          PanningMode="VerticalOnly"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center">

                <Canvas Width="900" Height="{Binding canvasHeight}">
                    <!-- Connectors layer (behind nodes) -->
                    <ItemsControl ItemsSource="{Binding connectors}"
                                  ItemsPanel="{StaticResource CanvasPanel}"
                                  ItemContainerStyle="{StaticResource ConnectorContainerStyle}"
                                  ItemTemplate="{StaticResource ConnectorTemplate}"/>

                    <!-- Nodes layer (on top) -->
                    <ItemsControl ItemsSource="{Binding nodes}"
                                  ItemsPanel="{StaticResource CanvasPanel}"
                                  ItemContainerStyle="{StaticResource NodeContainerStyle}"
                                  ItemTemplate="{StaticResource LevelNodeTemplate}"
                                  Canvas.ZIndex="1"/>
                </Canvas>
            </ScrollViewer>
        </Grid>

        <!-- Relic icons column (top-left corner) -->
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="32,24,0,0">
            <StackPanel.Visibility>
                <Binding Path="relicIconsVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </StackPanel.Visibility>
            <ItemsControl ItemsSource="{Binding relicIcons}"
                          ItemsPanel="{StaticResource VerticalRelicPanel}"
                          ItemTemplate="{StaticResource RelicIconTemplate}"/>
        </StackPanel>

        <!-- Relic popup tooltip overlay -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                Margin="{Binding relicPopupMargin}" Padding="40,32" CornerRadius="20"
                MaxWidth="640"
                BorderBrush="{StaticResource GoldBrush}" BorderThickness="4">
            <Border.Visibility>
                <Binding Path="relicPopupVisible">
                    <Binding.Converter>
                        <BooleanToVisibilityConverter/>
                    </Binding.Converter>
                </Binding>
            </Border.Visibility>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F52A1A0A" Offset="0"/>
                    <GradientStop Color="#F5382010" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <!-- Dismiss popup on tap anywhere on the card -->
            <b:Interaction.Triggers>
                <b:EventTrigger EventName="MouseLeftButtonUp">
                    <b:InvokeCommandAction Command="{Binding events.relicIconTap}"
                                           CommandParameter="__dismiss__"/>
                </b:EventTrigger>
            </b:Interaction.Triggers>
            <StackPanel>
                <TextBlock Text="{Binding relicPopupName}" FontSize="72" FontWeight="Bold"
                           FontFamily="Almendra" Foreground="{StaticResource GoldBrush}"
                           Margin="0,0,0,16"/>
                <TextBlock Text="{Binding relicPopupDescription}" FontSize="56"
                           FontFamily="Almendra" Foreground="{StaticResource ParchmentBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
