<Component xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:noesis="clr-namespace:NoesisGUIExtensions"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           mc:Ignorable="d"
           d:DesignWidth="1080" d:DesignHeight="1920">
  <noesis:LayoutScaler ReferenceResolution="1080,1920">
    <Grid>
      <!-- Full-screen dark overlay -->
      <Grid Background="#CC000000"/>

      <Grid x:Name="ContentContainer" Margin="48,120,48,120">
        <Grid.Visibility>
            <Binding Path="visible">
                <Binding.Converter>
                    <BooleanToVisibilityConverter/>
                </Binding.Converter>
            </Binding>
        </Grid.Visibility>

        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

          <!-- Title Banner -->
          <Grid HorizontalAlignment="Center" Margin="0,0,0,80">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
              <TextBlock Text="CHOOSE A RELIC" FontSize="96" FontWeight="Bold" Foreground="Black" FontFamily="Almendra" Margin="5,0,0,0"/>
              <TextBlock Text="CHOOSE A RELIC" FontSize="96" FontWeight="Bold" Foreground="Black" FontFamily="Almendra" Margin="-5,0,0,0"/>
              <TextBlock Text="CHOOSE A RELIC" FontSize="96" FontWeight="Bold" Foreground="Black" FontFamily="Almendra" Margin="0,5,0,0"/>
              <TextBlock Text="CHOOSE A RELIC" FontSize="96" FontWeight="Bold" Foreground="Black" FontFamily="Almendra" Margin="0,-5,0,0"/>
              <TextBlock Text="CHOOSE A RELIC" FontSize="96" FontWeight="Bold" Foreground="#f5c518" FontFamily="Almendra"/>
            </Grid>
          </Grid>

          <!-- Two Relic Cards Side by Side -->
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

            <!-- Relic Card 1 -->
            <Grid Margin="0,0,30,0">
              <Button Command="{Binding Path=events.relicCardTap}"
                      CommandParameter="{Binding Path=relic1Id}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      Width="440" Height="600">
                <Border CornerRadius="24"
                        BorderBrush="#f5c518"
                        BorderThickness="8"
                        Width="440" Height="600">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#2a1a0a" Offset="0"/>
                      <GradientStop Color="#1a1a2e" Offset="0.5"/>
                      <GradientStop Color="#2a1a0a" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <Grid Margin="28">
                    <!-- Corner ornaments -->
                    <Grid Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Card Content -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                      <!-- Relic Icon -->
                      <Border Width="160" Height="160" HorizontalAlignment="Center" Margin="0,0,0,30" CornerRadius="16" BorderBrush="#f5c518" BorderThickness="4">
                        <Border.Background>
                          <ImageBrush ImageSource="{Binding Path=relic1Icon}" Stretch="Uniform"/>
                        </Border.Background>
                      </Border>
                      <!-- Relic Name -->
                      <TextBlock Text="{Binding Path=relic1Name}"
                                 FontSize="52" FontWeight="Bold"
                                 Foreground="#f5c518"
                                 FontFamily="Almendra"
                                 HorizontalAlignment="Center"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Margin="0,0,0,24"/>
                      <!-- Divider -->
                      <Border Height="3" Background="#f5c518" Margin="20,0,20,24" Opacity="0.5"/>
                      <!-- Relic Description -->
                      <TextBlock Text="{Binding Path=relic1Description}"
                                 FontSize="40"
                                 Foreground="#c0c0d0"
                                 FontFamily="Almendra"
                                 HorizontalAlignment="Center"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
            </Grid>

            <!-- Relic Card 2 -->
            <Grid Margin="30,0,0,0">
              <Button Command="{Binding Path=events.relicCardTap}"
                      CommandParameter="{Binding Path=relic2Id}"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="0"
                      Width="440" Height="600">
                <Border CornerRadius="24"
                        BorderBrush="#f5c518"
                        BorderThickness="8"
                        Width="440" Height="600">
                  <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                      <GradientStop Color="#2a1a0a" Offset="0"/>
                      <GradientStop Color="#1a1a2e" Offset="0.5"/>
                      <GradientStop Color="#2a1a0a" Offset="1"/>
                    </LinearGradientBrush>
                  </Border.Background>
                  <Grid Margin="28">
                    <!-- Corner ornaments -->
                    <Grid Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Top">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Top">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid Width="28" Height="28" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                      <Ellipse Fill="#f5c518" Width="28" Height="28"/>
                      <Ellipse Fill="#b8860b" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Card Content -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="20">
                      <!-- Relic Icon -->
                      <Border Width="160" Height="160" HorizontalAlignment="Center" Margin="0,0,0,30" CornerRadius="16" BorderBrush="#f5c518" BorderThickness="4">
                        <Border.Background>
                          <ImageBrush ImageSource="{Binding Path=relic2Icon}" Stretch="Uniform"/>
                        </Border.Background>
                      </Border>
                      <!-- Relic Name -->
                      <TextBlock Text="{Binding Path=relic2Name}"
                                 FontSize="52" FontWeight="Bold"
                                 Foreground="#f5c518"
                                 FontFamily="Almendra"
                                 HorizontalAlignment="Center"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"
                                 Margin="0,0,0,24"/>
                      <!-- Divider -->
                      <Border Height="3" Background="#f5c518" Margin="20,0,20,24" Opacity="0.5"/>
                      <!-- Relic Description -->
                      <TextBlock Text="{Binding Path=relic2Description}"
                                 FontSize="40"
                                 Foreground="#c0c0d0"
                                 FontFamily="Almendra"
                                 HorizontalAlignment="Center"
                                 TextWrapping="Wrap"
                                 TextAlignment="Center"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </Button>
            </Grid>

          </StackPanel>

        </StackPanel>
      </Grid>
    </Grid>
  </noesis:LayoutScaler>
</Component>
