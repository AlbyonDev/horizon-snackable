<Component xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:noesis="clr-namespace:NoesisGUIExtensions"
           mc:Ignorable="d">
  <noesis:LayoutScaler ReferenceResolution="1080,1920">
    <Grid>
      <Grid x:Name="ContentContainer" Margin="48,240,48,120">
        <!-- Save indicator - bottom-left, above joystick reserved zone -->
        <Grid x:Name="SavePanel"
              HorizontalAlignment="Left"
              VerticalAlignment="Bottom"
              Margin="0,0,0,340"
              Opacity="0">
          <Grid.RenderTransform>
            <TransformGroup>
              <ScaleTransform/>
              <SkewTransform/>
              <RotateTransform/>
              <TranslateTransform/>
            </TransformGroup>
          </Grid.RenderTransform>

          <Border Background="#AA000000"
                  CornerRadius="12"
                  Padding="24,14,24,14">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#x1F4BE;"
                         FontSize="36"
                         Foreground="White"
                         VerticalAlignment="Center"
                         Margin="0,0,12,0"/>
              <TextBlock Text="Saving..."
                         FontSize="36"
                         FontFamily="Kallisto"
                         Foreground="#CCFFFFFF"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </Grid>
  </noesis:LayoutScaler>

  <Component.Resources>
    <!-- Fade in + slight slide up -->
    <Storyboard x:Key="FadeIn">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavePanel"
                                      Storyboard.TargetProperty="Opacity">
        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="1">
          <EasingDoubleKeyFrame.EasingFunction>
            <QuadraticEase EasingMode="EaseOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
      </DoubleAnimationUsingKeyFrames>
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavePanel"
                                      Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[3].(TranslateTransform.Y)">
        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="20"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <QuadraticEase EasingMode="EaseOut"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- Fade out -->
    <Storyboard x:Key="FadeOut">
      <DoubleAnimationUsingKeyFrames Storyboard.TargetName="SavePanel"
                                      Storyboard.TargetProperty="Opacity">
        <LinearDoubleKeyFrame KeyTime="0:0:0" Value="1"/>
        <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="0">
          <EasingDoubleKeyFrame.EasingFunction>
            <QuadraticEase EasingMode="EaseIn"/>
          </EasingDoubleKeyFrame.EasingFunction>
        </EasingDoubleKeyFrame>
      </DoubleAnimationUsingKeyFrames>
    </Storyboard>
  </Component.Resources>

  <b:Interaction.Triggers>
    <!-- Trigger fade in when isVisible becomes true -->
    <b:DataTrigger Binding="{Binding Path=isVisible}" Value="True">
      <b:ControlStoryboardAction Storyboard="{DynamicResource FadeIn}"/>
    </b:DataTrigger>
    <!-- Trigger fade out when isVisible becomes false -->
    <b:DataTrigger Binding="{Binding Path=isVisible}" Value="False">
      <b:ControlStoryboardAction Storyboard="{DynamicResource FadeOut}"/>
    </b:DataTrigger>
  </b:Interaction.Triggers>
</Component>
